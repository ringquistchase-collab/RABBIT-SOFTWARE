🧠 HUMAN DETECTION MODULE

class HumanDetectionEngine:

    def detect(self, event):
        signals = {
            "user_session": event.get("user_id") is not None,
            "api_trigger": event.get("source") == "api",
            "admin_action": event.get("role") == "admin",
            "prod_change": event.get("env") == "production",
            "security_sensitive": event.get("security_flag", False)
        }

        score = sum(signals.values()) / len(signals)

        return {
            "human_present": signals["user_session"],
            "confidence": score,
            "requires_approval": score > 0.6 or signals["security_sensitive"]
        }


