            'template_id': self.template_id,
            'signature': self.template_signature,
            'prediction_weights': self.prediction_weights,
            'intervention_triggers': self.intervention_triggers,
            'source_event': self.source_event,
            'version': '1.0',
            'api_endpoint': '/api/v1/templates/sensory_deprivation'
        }
   
    def match_current_state(self, current_chemicals: Dict) -> Dict:
        """Match current chemical state against this template"""
        match_score = 0.0
        alerts = []
       
        # Check dopamine drop
        if current_chemicals.get('dopamine_drop', 0) >= self.template_signature['dopamine_drop_threshold']:
            match_score += 0.3
            alerts.append('DOPAMINE_DROP_ALERT')
       
        # Check serotonin drop
        if current_chemicals.get('serotonin_drop', 0) >= self.template_signature['serotonin_drop_threshold']:
            match_score += 0.4
            alerts.append('SEROTONIN_DROP_ALERT')
       
        # Check oxytocin drop
        if current_chemicals.get('oxytocin_drop', 0) >= self.template_signature['oxytocin_drop_threshold']:
            match_score += 0.2
            alerts.append('OXYTOCIN_DROP_ALERT')
       
        # Check cortisol elevation
        if current_chemicals.get('cortisol_rise', 0) >= self.template_signature['cortisol_elevation_threshold']:
            match_score += 0.1
            alerts.append('CORTISOL_ELEVATION_ALERT')
       
        return {
            'match_score': match_score,
            'is_match': match_score >= 0.7,
            'alerts': alerts,
            'template_id': self.template_id,
            'recommended_action': self._get_action(match_score)
        }
   
    def _get_action(self, score: float) -> str:
        if score >= 0.8:
            return "IMMEDIATE_INTERVENTION_REQUIRED"
        elif score >= 0.6:
            return "MONITOR_CLOSELY"
        elif score >= 0.4:
            return "INCREASE_CHECK_FREQUENCY"
        else:
            return "NORMAL_MONITORING"


