        print(f"   External Manipulation: BLOCKED")
   
    def auto_tune(self, node_id: str, environmental_conditions: Dict[str, float]) -> Dict:
        """
        Automatically tune node based on environmental conditions
        ONLY uses self-reported conditions - no external input
        """
        if node_id not in self.configurator.nodes:
            return {'error': 'Node not found'}
       
        node = self.configurator.nodes[node_id]
        adjustments = {}
       
        # Temperature compensation (self-calibrated)
        temp_c = environmental_conditions.get('temperature_c', 22.0)
        temp_adjustment = (temp_c - 22.0) * self.configurator.ENVIRONMENTAL_TUNING['temperature_compensation']
        adjustments['frequency_adjustment_ghz'] = temp_adjustment
        adjustments['temperature_c'] = temp_c
       
        # Humidity adjustment
        humidity = environmental_conditions.get('humidity_percent', 50.0)
        humidity_adjustment = (humidity - 50.0) * self.configurator.ENVIRONMENTAL_TUNING['humidity_factor']
        adjustments['humidity_adjustment'] = humidity_adjustment
       
        # Update tuning parameters
        tuning_update = {
            'temperature_compensation': self.configurator.ENVIRONMENTAL_TUNING['temperature_compensation'],
            'humidity_factor': self.configurator.ENVIRONMENTAL_TUNING['humidity_factor'],
            'last_tuning_temp': temp_c,
            'last_tuning_humidity': humidity
        }
       
        self.configurator.update_node_tuning(node_id, tuning_update)
       
        tuning_record = {
            'timestamp': time.time(),
            'node_id': node_id,
            'node_name': node.name,
            'adjustments': adjustments,
            'performed_by': CHASE_NAME
        }
        self.tuning_history.append(tuning_record)
       
        print(f"   🔧 Auto-tuned {node.name}: {adjustments}")
       
        return {
            'status': 'tuned',
            'node': node.name,
            'adjustments': adjustments,
            'method': 'self_calibration'
        }
   
    def get_tuning_history(self) -> List[Dict]:
        """Get tuning history (audit trail)"""
        return self.tuning_history[-20:]


