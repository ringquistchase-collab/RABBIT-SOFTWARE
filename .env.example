VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_SUPABASE_ANON_KEY=your-anon-key

# Supabase Edge Functions (server-side only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# NOAA polling station (ICAO code, e.g. KORD = Chicago, KLAX = LA)
NOAA_STATION_ID=KORD

# AI router — set whichever providers you have keys for
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_URL=http://localhost:11434

# Vector embeddings — pgvector (enable in Supabase dashboard: Extensions → vector)
# Model: OpenAI text-embedding-3-small (768 dims) or Ollama nomic-embed-text (no key needed)
# To use Ollama: run: ollama pull nomic-embed-text

# Data lifecycle — GCS archival
GCS_BUCKET=rabbitos-archive
HOT_TIER_DAYS=7
# GCS_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Ethereum / eth-anchor
ETH_RPC_URL=https://ethereum.publicnode.com
ETHERSCAN_API_KEY=
# WALLET_PRIVATE_KEY=   <-- add this secret to enable transaction signing

# Grafana
GRAFANA_ADMIN_PASSWORD=rabbitos
SUPABASE_DB_HOST=db.your-project.supabase.co
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your-db-password
