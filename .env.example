VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_SUPABASE_ANON_KEY=your-anon-key

# Supabase Edge Functions (server-side only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# NOAA polling station (ICAO code, e.g. KORD = Chicago, KLAX = LA)
NOAA_STATION_ID=KORD

# AI router — set whichever providers you have keys for
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_URL=http://localhost:11434

# Grafana
GRAFANA_ADMIN_PASSWORD=rabbitos
SUPABASE_DB_HOST=db.your-project.supabase.co
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your-db-password
