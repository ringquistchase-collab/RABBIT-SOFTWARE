class TemplateAttachmentEngine:
    """
    Handles attaching templates to various external entities
    Each attachment creates a verifiable link
    """
    
    def __init__(self, roi_engine: ReleaseOfInformationEngine):
        self.roi_engine = roi_engine
        self.attachments: Dict[str, TemplateAttachment] = {}
        
    def attach_to_blockchain(self, 
                             template_id: str,
                             smart_contract_address: str,
                             chain: str = "ethereum",
                             permissions: List[str] = None) -> Dict:
        """
        Attach template to a blockchain smart contract
        Allows smart contract to verify person's attributes
        """
        attachment_id = hashlib.sha3_256(
            f"{template_id}_{smart_contract_address}_{time.time()}".encode()
        ).hexdigest()[:16]
        
        # Create on-chain verification method
        onchain_data = {
            'attachment_id': attachment_id,
            'template_hash': hashlib.sha3_256(template_id.encode()).hexdigest(),
            'contract': smart_contract_address,
            'chain': chain,
            'verified_attributes': permissions or []
        }
        
        attachment = TemplateAttachment(
            attachment_id=attachment_id,
            template_id=template_id,
            attachment_type=AttachmentType.BLOCKCHAIN_SMART_CONTRACT,
            target_identifier=smart_contract_address,
            attached_at=time.time(),
            expires_at=time.time() + (365 * 86400),  # 1 year
            permissions=permissions or [],
            attachment_signature=hashlib.sha3_256(json.dumps(onchain_data).encode()).hexdigest()
        )
        
        self.attachments[attachment_id] = attachment
        
        return {
            'attachment_id': attachment_id,
            'contract': smart_contract_address,
            'verification_method': 'onchain_hash_match',
            'explorer_url': f"https://{chain}.etherscan.io/address/{smart_contract_address}"
        }
    
    def attach_to_digital_wallet(self,
                                 template_id: str,
                                 wallet_address: str,
                                 wallet_type: str = "metamask") -> Dict:
        """
        Attach template to a digital wallet (crypto wallet)
        Enables wallet to use template for personalized experiences
        """
        attachment_id = hashlib.sha3_256(
            f"{template_id}_{wallet_address}_{time.time()}".encode()
        ).hexdigest()[:16]
        
        attachment = TemplateAttachment(
            attachment_id=attachment_id,
            template_id=template_id,
            attachment_type=AttachmentType.DIGITAL_WALLET,
            target_identifier=wallet_address,
            attached_at=time.time(),
            expires_at=time.time() + (90 * 86400),  # 90 days
            permissions=['read_profile', 'personalized_content'],
            attachment_signature=hashlib.sha3_256(f"{template_id}{wallet_address}".encode()).hexdigest()
        )
        
        self.attachments[attachment_id] = attachment
        
        return {
            'attachment_id': attachment_id,
            'wallet': wallet_address,
            'type': wallet_type,
            'verification': 'wallet_signature_required'
        }
    
    def attach_to_medical_record(self,
                                 template_id: str,
                                 ehr_system: str,
                                 patient_id: str,
                                 hipaa_compliant: bool = True) -> Dict:
        """
        Attach template to electronic health record (EHR)
        Enables medical systems to use neural data alongside clinical data
        """
        attachment_id = hashlib.sha3_256(
            f"{template_id}_{ehr_system}_{patient_id}".encode()
        ).hexdigest()[:16]
        
        # Create HIPAA-compliant release
        medical_release = self.roi_engine.create_release_of_notes(
            person_id=patient_id,
            template={'features': {}},  # Simplified
            release_level=ReleaseOfInformationLevel.VERIFIED_CLAIMS,
            purpose="Medical research support",
            recipient=ehr_system,
            duration_days=365
        )
        
        attachment = TemplateAttachment(
            attachment_id=attachment_id,
            template_id=template_id,
            attachment_type=AttachmentType.MEDICAL_RECORD,
            target_identifier=f"{ehr_system}:{patient_id}",
            attached_at=time.time(),
            expires_at=time.time() + (365 * 86400),
            permissions=['read_verified_claims', 'clinical_correlation'],
            attachment_signature=medical_release.current_release_hash,
            release_notes=[{
                'release_id': medical_release.release_id,
                'release_hash': medical_release.current_release_hash,
                'issued_at': medical_release.issued_at
            }]
        )
        
        self.attachments[attachment_id] = attachment
        
        return {
            'attachment_id': attachment_id,
            'ehr_system': ehr_system,
            'patient_id': patient_id,
            'hipaa_compliant': hipaa_compliant,
            'release_id': medical_release.release_id
        }
    
    def attach_to_research_study(self,
                                  template_id: str,
                                  study_id: str,
                                  institution: str,
                                  consent_form_signed: bool = True) -> Dict:
        """
        Attach template to a research study
        Enables participation in studies with controlled data release
        """
        attachment_id = hashlib.sha3_256(
            f"{template_id}_{study_id}_{institution}".encode()
        ).hexdigest()[:16]
        
        # Create research-specific release
        research_release = self.roi_engine.create_release_of_notes(
            person_id=f"participant_{attachment_id[:8]}",
            template={'features': {}},
            release_level=ReleaseOfInformationLevel.DERIVED_FEATURES,
            purpose=f"Research study: {study_id}",
            recipient=institution,
            duration_days=730  # 2 years
        )
        
        attachment = TemplateAttachment(
            attachment_id=attachment_id,
            template_id=template_id,
            attachment_type=AttachmentType.RESEARCH_DATASET,
            target_identifier=f"{institution}:{study_id}",
            attached_at=time.time(),
            expires_at=time.time() + (730 * 86400),
            permissions=['research_use', 'anonymized_analysis'],
            attachment_signature=research_release.current_release_hash,
            release_notes=[{
                'release_id': research_release.release_id,
                'study_id': study_id,
                'consent': consent_form_signed
            }]
        )
        
        self.attachments[attachment_id] = attachment
        
        return {
            'attachment_id': attachment_id,
            'study_id': study_id,
            'institution': institution,
            'release_id': research_release.release_id,
            'data_use_agreement': 'anonymized_features_only'
        }


