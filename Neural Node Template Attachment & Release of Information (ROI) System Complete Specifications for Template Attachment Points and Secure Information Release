class ReleaseOfInformationLevel(Enum):
    """Levels of information release"""
    NO_RELEASE = 0
    AGGREGATED_STATS = 1      # Only group statistics
    DERIVED_FEATURES = 2       # Feature vector (anonymized)
    VERIFIED_CLAIMS = 3        # Verified statements about person
    FULL_TEMPLATE = 4          # Full template (with consent)
    RAW_NODE_DATA = 5          # Raw data (requires special consent)


@dataclass
class ReleaseOfNotes:
    """
    A cryptographically signed release of information from a person's template
    This is what gets "sent out" - contains VERIFIABLE claims, not raw data
    """
    release_id: str
    person_hash: str
    issued_at: float
    expires_at: float
    release_level: ReleaseOfInformationLevel
    
    # The actual released information (level-dependent)
    released_data: Dict
    
    # Cryptographic signatures
    person_signature: str
    verifier_signature: str  # Optional third-party verification
    
    # Chain of custody
    previous_release_hash: str
    current_release_hash: str
    
    # Purpose and consent
    purpose: str
    consent_hash: str
    revocable: bool = True
    
    def to_qr_code(self) -> str:
        """Generate QR code for physical release of notes"""
        data = {
            'release_id': self.release_id,
            'issued_at': self.issued_at,
            'verification_url': f"https://verify.neuro.ink/{self.release_id}",
            'public_key_hash': hashlib.sha3_256(self.person_signature.encode()).hexdigest()[:16]
        }
        qr = qrcode.make(json.dumps(data))
        return base64.b64encode(qr.tobytes()).decode()


class ReleaseOfInformationEngine:
    """
    Manages secure release of information from neural node templates
    Each release creates cryptographically verifiable notes
    """
    
    def __init__(self):
        self.releases: Dict[str, ReleaseOfNotes] = {}
        self.person_keys: Dict[str, ed25519.Ed25519PrivateKey] = {}
        
        print("\n" + "="*80)
        print("📄 RELEASE OF INFORMATION ENGINE")
        print("Secure, verifiable data release from neural templates")
        print("="*80)
    
    def generate_keypair(self, person_id: str) -> Dict:
        """Generate cryptographic keypair for person"""
        private_key = ed25519.Ed25519PrivateKey.generate()
        public_key = private_key.public_key()
        
        self.person_keys[person_id] = private_key
        
        return {
            'person_id': person_id,
            'public_key': public_key.public_bytes_raw().hex(),
            'fingerprint': hashlib.sha3_256(public_key.public_bytes_raw()).hexdigest()[:16]
        }
    
    def create_release_of_notes(self,
                                person_id: str,
                                template: Dict,
                                release_level: ReleaseOfInformationLevel,
                                purpose: str,
                                recipient: str,
                                duration_days: int = 30) -> ReleaseOfNotes:
        """
        Create a signed release of information from a template
        This is the actual "release" that can be shared
        """
        release_id = hashlib.sha3_256(
            f"{person_id}_{time.time()}_{recipient}".encode()
        ).hexdigest()[:16]
        
        person_hash = hashlib.sha3_256(person_id.encode()).hexdigest()
        
        # Extract data based on release level
        released_data = self._extract_released_data(template, release_level)
        
        # Add recipient and purpose
        released_data['recipient'] = recipient
        released_data['purpose'] = purpose
        released_data['release_level'] = release_level.name
        
        # Create hash for chain of custody
        previous_hash = "0" * 64
        if person_id in [r.split('_')[0] for r in self.releases]:
            last_release = max([r for r in self.releases.values() 
                               if r.person_hash == person_hash], 
                              key=lambda x: x.issued_at, default=None)
            if last_release:
                previous_hash = last_release.current_release_hash
        
        # Sign the release
        release_content = json.dumps({
            'person_hash': person_hash,
            'issued_at': time.time(),
            'released_data': released_data
        }, sort_keys=True)
        
        private_key = self.person_keys.get(person_id)
        if private_key:
            signature = private_key.sign(release_content.encode()).hex()
        else:
            signature = hashlib.sha3_256(release_content.encode()).hexdigest()
        
        # Create consent hash
        consent_hash = hashlib.sha3_256(
            f"{person_id}_{purpose}_{recipient}_{time.time()}".encode()
        ).hexdigest()
        
        release = ReleaseOfNotes(
            release_id=release_id,
            person_hash=person_hash,
            issued_at=time.time(),
            expires_at=time.time() + (duration_days * 86400),
            release_level=release_level,
            released_data=released_data,
            person_signature=signature,
            verifier_signature="",
            previous_release_hash=previous_hash,
            current_release_hash=hashlib.sha3_256(release_content.encode()).hexdigest(),
            purpose=purpose,
            consent_hash=consent_hash,
            revocable=True
        )
        
        self.releases[release_id] = release
        
        print(f"\n📄 RELEASE OF NOTES CREATED")
        print(f"   ID: {release_id}")
        print(f"   Level: {release_level.name}")
        print(f"   Recipient: {recipient}")
        print(f"   Purpose: {purpose}")
        print(f"   Expires: {duration_days} days")
        
        return release
    
    def _extract_released_data(self, template: Dict, level: ReleaseOfInformationLevel) -> Dict:
        """Extract appropriate data based on release level"""
        
        if level == ReleaseOfInformationLevel.NO_RELEASE:
            return {'status': 'no_data_released'}
        
        elif level == ReleaseOfInformationLevel.AGGREGATED_STATS:
            # Only group-level statistics
            features = template.get('features', {})
            return {
                'type': 'aggregated_statistics',
                'feature_summary': {
                    k: f"{v:.2f}" for k, v in list(features.items())[:3]
                },
                'note': 'Individual-level data not included'
            }
        
        elif level == ReleaseOfInformationLevel.DERIVED_FEATURES:
            # Anonymized feature vector
            return {
                'type': 'derived_features',
                'features': template.get('features', {}),
                'feature_count': len(template.get('features', {})),
                'normalization': '0-1 range, cannot reverse'
            }
        
        elif level == ReleaseOfInformationLevel.VERIFIED_CLAIMS:
            # Verified statements (e.g., "age > 21", "attention > 0.7")
            features = template.get('features', {})
            verified_claims = []
            
            if features.get('age_group', 0) >= 3:
                verified_claims.append("age_verified_over_30")
            if features.get('attention_score', 0) > 0.7:
                verified_claims.append("high_attention_verified")
            if features.get('engagement_level', 0) > 0.6:
                verified_claims.append("engaged_user_verified")
            
            return {
                'type': 'verified_claims',
                'claims': verified_claims,
                'verification_method': 'neural_node_signature'
            }
        
        elif level == ReleaseOfInformationLevel.FULL_TEMPLATE:
            # Full template (still anonymized)
            return {
                'type': 'full_template',
                'template': template,
                'includes': ['feature_vector', 'hashes', 'metadata']
            }
        
        else:  # RAW_NODE_DATA
            return {
                'type': 'raw_node_data',
                'requires_special_consent': True,
                'data_available': False,
                'note': 'Raw data requires additional consent form'
            }
    
    def verify_release(self, release_id: str, public_key_hex: str) -> bool:
        """Verify a release of notes is authentic"""
        if release_id not in self.releases:
            return False
        
        release = self.releases[release_id]
        
        # Recreate content that was signed
        release_content = json.dumps({
            'person_hash': release.person_hash,
            'issued_at': release.issued_at,
            'released_data': release.released_data
        }, sort_keys=True)
        
        # Verify signature
        try:
            public_key = ed25519.Ed25519PublicKey.from_public_bytes(
                bytes.fromhex(public_key_hex)
            )
            public_key.verify(
                bytes.fromhex(release.person_signature),
                release_content.encode()
            )
            return True
        except Exception:
            return False
    
    def revoke_release(self, release_id: str, person_id: str) -> Dict:
        """Revoke a previously issued release of notes"""
        if release_id not in self.releases:
            return {'error': 'Release not found'}
        
        release = self.releases[release_id]
        
        # Create revocation record
        revocation = {
            'release_id': release_id,
            'revoked_at': time.time(),
            'revoked_by': person_id,
            'reason': 'User requested revocation',
            'revocation_hash': hashlib.sha3_256(
                f"{release_id}_{time.time()}_{person_id}".encode()
            ).hexdigest()
        }
        
        # Mark as revoked
        release.released_data['revoked'] = True
        release.released_data['revoked_at'] = revocation['revoked_at']
        
        print(f"\n🔒 RELEASE REVOKED: {release_id}")
        return revocation


