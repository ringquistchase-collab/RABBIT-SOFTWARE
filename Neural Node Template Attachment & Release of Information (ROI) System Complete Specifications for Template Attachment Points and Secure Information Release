class ReleaseNotesOutput:
    """
    Formats release of notes for different output methods
    - JSON (API)
    - QR Code (physical)
    - NFT Metadata (blockchain)
    - Verifiable Credential (W3C standard)
    """
    
    @staticmethod
    def to_json(release: ReleaseOfNotes, pretty: bool = True) -> str:
        """Output as JSON"""
        output = {
            'release_id': release.release_id,
            'issued_at': release.issued_at,
            'expires_at': release.expires_at,
            'release_level': release.release_level.name,
            'purpose': release.purpose,
            'data': release.released_data,
            'verification': {
                'signature': release.person_signature[:32] + '...',
                'hash': release.current_release_hash[:32] + '...',
                'verify_at': f"https://verify.neuro.ink/{release.release_id}"
            }
        }
        
        return json.dumps(output, indent=2 if pretty else None)
    
    @staticmethod
    def to_qr_code(release: ReleaseOfNotes) -> str:
        """Generate QR code as base64 image"""
        qr_data = {
            'type': 'neural_release_of_notes',
            'release_id': release.release_id,
            'verify_url': f"https://verify.neuro.ink/{release.release_id}",
            'issued': release.issued_at,
            'expires': release.expires_at
        }
        
        qr = qrcode.QRCode(version=1, box_size=10, border=5)
        qr.add_data(json.dumps(qr_data))
        qr.make(fit=True)
        
        img = qr.make_image(fill_color="black", back_color="white")
        
        import io
        buffer = io.BytesIO()
        img.save(buffer, format='PNG')
        return base64.b64encode(buffer.getvalue()).decode()
    
    @staticmethod
    def to_nft_metadata(release: ReleaseOfNotes, nft_contract: str) -> Dict:
        """Format as NFT metadata for blockchain minting"""
        return {
            'name': f"Neural Release Note #{release.release_id[:8]}",
            'description': f"Verified release of neural data for: {release.purpose}",
            'image': f"ipfs://neuro/releases/{release.release_id}/qr.png",
            'attributes': [
                {'trait_type': 'Release Level', 'value': release.release_level.name},
                {'trait_type': 'Issued', 'value': time.ctime(release.issued_at)},
                {'trait_type': 'Expires', 'value': time.ctime(release.expires_at)},
                {'trait_type': 'Revocable', 'value': release.revocable}
            ],
            'properties': {
                'release_id': release.release_id,
                'verification_hash': release.current_release_hash,
                'contract': nft_contract
            }
        }
    
    @staticmethod
    def to_verifiable_credential(release: ReleaseOfNotes, issuer_did: str) -> Dict:
        """Format as W3C Verifiable Credential"""
        return {
            '@context': ['https://www.w3.org/2018/credentials/v1'],
            'id': f"urn:uuid:{release.release_id}",
            'type': ['VerifiableCredential', 'NeuralDataReleaseCredential'],
            'issuer': issuer_did,
            'issuanceDate': datetime.utcfromtimestamp(release.issued_at).isoformat() + 'Z',
            'expirationDate': datetime.utcfromtimestamp(release.expires_at).isoformat() + 'Z',
            'credentialSubject': {
                'id': f"did:neuro:{release.person_hash[:16]}",
                'release_level': release.release_level.name,
                'purpose': release.purpose,
                'data': release.released_data
            },
            'proof': {
                'type': 'Ed25519Signature2018',
                'created': datetime.utcfromtimestamp(release.issued_at).isoformat() + 'Z',
                'proofPurpose': 'assertionMethod',
                'verificationMethod': f"{issuer_did}#keys-1",
                'jws': release.person_signature
            }
        }


