class NeuralImageGenerator:
    """
    Generates images from neural memory tokens using LLM + Diffusion
    """
   
    def __init__(self, api_key: str = None):
        self.client = None
        self.diffusion_pipeline = None
       
        if HAS_OPENAI and api_key:
            self.client = OpenAI(api_key=api_key)
            print("🤖 LLM Connected")
       
        if HAS_DIFFUSERS and torch.cuda.is_available():
            try:
                self.diffusion_pipeline = StableDiffusionPipeline.from_pretrained(
                    "runwayml/stable-diffusion-v1-5",
                    torch_dtype=torch.float16
                )
                self.diffusion_pipeline.to("cuda")
                print("🎨 Diffusion Model Loaded (GPU)")
            except:
                print("⚠️ Diffusion model not loaded - using simulation")
   
    def generate_image_from_tokens(self, tokens: List[str], memory_context: str) -> Dict:
        """
        Generate image from neural tokens
        Returns base64 encoded image and metadata
        """
        # Convert tokens to prompt
        token_string = ''.join(tokens)
        token_hash = hashlib.sha256(token_string.encode()).hexdigest()[:8]
       
        # Create image generation prompt
        prompt = self._create_image_prompt(token_string, memory_context, token_hash)
       
        print(f"\n🎨 Generating Image from Neural Tokens...")
        print(f"   Prompt: {prompt[:100]}...")
       
        # Generate image
        if self.diffusion_pipeline:
            image = self._generate_with_diffusion(prompt)
        else:
            image = self._generate_simulated_image(token_hash, token_string)
       
        # Convert to base64 for transmission
        buffered = io.BytesIO()
        image.save(buffered, format="PNG")
        img_base64 = base64.b64encode(buffered.getvalue()).decode()
       
        return {
            "image_base64": img_base64[:100] + "...",  # Truncated for display
            "prompt": prompt,
            "token_hash": token_hash,
            "image_size": len(img_base64),
            "generated_at": time.time()
        }
   
    def _create_image_prompt(self, token_string: str, context: str, token_hash: str) -> str:
        """Create detailed image generation prompt from tokens"""
       
        # Extract semantic meaning from token pattern
        bits = [int(b) for b in token_string[:64]]
       
        # Calculate token features
        ones_ratio = sum(bits) / len(bits) if bits else 0
        complexity = len(set(token_string)) / 16
       
        # Map token features to image attributes
        if ones_ratio > 0.7:
            color_theme = "bright, vibrant, high contrast"
            mood = "energetic, positive"
        elif ones_ratio < 0.3:
            color_theme = "dark, muted, low contrast"
            mood = "calm, serene, meditative"
        else:
            color_theme = "balanced, natural tones"
            mood = "neutral, balanced"
       
        if complexity > 0.8:
            detail = "highly detailed, complex patterns, intricate textures"
        else:
            detail = "simple, clean, minimalist"
       
        prompt = f"""{mood} {color_theme} {detail} scene.

Neural memory signature: {token_hash}
Memory context: {context}

Style: Dreamlike, neural network visualization, brain activity visualization.
Quality: 8k resolution, photorealistic rendering.

Generated from EEG memory trace {token_hash[:8]}."""
       
        return prompt
   
    def _generate_with_diffusion(self, prompt: str) -> Image.Image:
        """Generate image using Stable Diffusion"""
        try:
            with torch.no_grad():
                image = self.diffusion_pipeline(
                    prompt,
                    num_inference_steps=30,
                    guidance_scale=7.5
                ).images[0]
            return image
        except Exception as e:
            print(f"Diffusion error: {e}")
            return self._generate_simulated_image("error", prompt)
   
    def _generate_simulated_image(self, token_hash: str, token_string: str) -> Image.Image:
        """Generate simulated image when diffusion not available"""
        # Create a deterministic pattern image from tokens
        size = 512
        img_array = np.zeros((size, size, 3), dtype=np.uint8)
       
        # Use token string to deterministically generate pattern
        np.random.seed(int(token_hash[:8], 16) if token_hash[:8] else 0)
       
        # Create neural network style pattern
        for i in range(100):
            x = np.random.randint(0, size)
            y = np.random.randint(0, size)
            color = np.random.randint(0, 255, 3)
            radius = np.random.randint(1, 10)
            cv2.circle(img_array, (x, y), radius, tuple(map(int, color)), -1)
       
        return Image.fromarray(img_array)


