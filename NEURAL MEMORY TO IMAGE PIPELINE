class BrainRegion(Enum):
    PREFRONTAL_CORTEX = "prefrontal_cortex"    # Working memory
    HIPPOCAMPUS = "hippocampus"                # Memory formation
    VISUAL_CORTEX = "visual_cortex"            # Image processing
    MOTOR_CORTEX = "motor_cortex"              # Action planning
    SOMATOSENSORY = "somatosensory"            # Sensory input


@dataclass
class NeuralMemoryTrace:
    """
    A neural memory trace - the physical representation of a memory
    Formed by simultaneous activation of specific node clusters
    """
    memory_id: str
    timestamp: float
    activated_nodes: List[str]
    activation_pattern: np.ndarray  # 2D pattern of activations
    strength: float                  # 0-1 memory strength
    region: BrainRegion
    rf_signature: str                # Unique RF fingerprint of this memory
   
class NeuralNode:
    """Individual neural node in the brain network"""
   
    def __init__(self, node_id: str, region: BrainRegion, x: float, y: float, z: float):
        self.node_id = node_id
        self.region = region
        self.position = (x, y, z)
        self.activation_state = 0.0  # 0-1 firing rate
        self.memory_traces = []       # Memories stored in this node
        self.rf_frequency = self._calc_rf_frequency(region)
        self.synaptic_weights = {}    # Connections to other nodes
       
    def _calc_rf_frequency(self, region: BrainRegion) -> float:
        """Calculate RF frequency for this node based on brain region"""
        base_freqs = {
            BrainRegion.PREFRONTAL_CORTEX: 10.25,
            BrainRegion.HIPPOCAMPUS: 10.18,
            BrainRegion.VISUAL_CORTEX: 10.22,
            BrainRegion.MOTOR_CORTEX: 10.23,
            BrainRegion.SOMATOSENSORY: 10.20
        }
        return base_freqs.get(region, 10.20) + np.random.uniform(-0.02, 0.02)
   
    def activate(self, stimulus: float) -> float:
        """Activate node with given stimulus strength"""
        # Hebbian activation with threshold
        self.activation_state = np.tanh(stimulus * self._get_excitability())
        return self.activation_state
   
    def _get_excitability(self) -> float:
        """Get node excitability based on position and region"""
        if self.region == BrainRegion.HIPPOCAMPUS:
            return 0.9  # Highly excitable (memory formation)
        elif self.region == BrainRegion.VISUAL_CORTEX:
            return 0.8
        else:
            return 0.6
   
    def store_memory(self, activation_pattern: np.ndarray, strength: float) -> NeuralMemoryTrace:
        """Store a memory trace in this node"""
        memory = NeuralMemoryTrace(
            memory_id=hashlib.sha256(f"{self.node_id}_{time.time()}_{strength}".encode()).hexdigest()[:16],
            timestamp=time.time(),
            activated_nodes=[self.node_id],
            activation_pattern=activation_pattern,
            strength=strength,
            region=self.region,
            rf_signature=hashlib.sha256(str(self.rf_frequency).encode()).hexdigest()[:16]
        )
        self.memory_traces.append(memory)
        return memory


class NeuralMemoryNetwork:
    """Network of neural nodes that form and retrieve memories"""
   
    # Human brain inspired: 86B neurons → scaled to 10,000 nodes for simulation
    NODES_PER_REGION = 2000  # 2000 nodes per region × 5 regions = 10,000 nodes
   
    def __init__(self):
        self.nodes: Dict[str, NeuralNode] = {}
        self.active_memories: List[NeuralMemoryTrace] = []
        self.node_by_region: Dict[BrainRegion, List[NeuralNode]] = {r: [] for r in BrainRegion}
       
        self._create_nodes()
        self._create_synaptic_connections()
       
        print(f"🧠 Neural Memory Network Created")
        print(f"   Total Nodes: {len(self.nodes)}")
        print(f"   Nodes per Region: {self.NODES_PER_REGION}")
   
    def _create_nodes(self):
        """Create nodes distributed across brain regions"""
        node_id = 0
        for region in BrainRegion:
            for i in range(self.NODES_PER_REGION):
                # Position within region (3D coordinates in mm)
                x = np.random.uniform(-50, 50)
                y = np.random.uniform(-50, 50)
                z = np.random.uniform(-30, 30)
               
                node = NeuralNode(f"N_{region.value[:3]}_{i:04d}", region, x, y, z)
                self.nodes[node.node_id] = node
                self.node_by_region[region].append(node)
                node_id += 1
   
    def _create_synaptic_connections(self):
        """Create synaptic connections between nodes (sparse, like brain)"""
        connection_count = 0
        for node in self.nodes.values():
            # Each node connects to ~1000 other nodes (sparse connectivity)
            num_connections = np.random.poisson(1000)
            potential_targets = list(self.nodes.values())
            targets = np.random.choice(potential_targets, min(num_connections, len(potential_targets)), replace=False)
           
            for target in targets:
                if target.node_id != node.node_id:
                    # Synaptic weight based on Hebbian learning
                    weight = np.random.beta(0.5, 0.5) * 0.1
                    node.synaptic_weights[target.node_id] = weight
                    connection_count += 1
       
        print(f"   Synaptic Connections Created: {connection_count:,}")
   
    def form_memory(self, stimulus_pattern: np.ndarray, region: BrainRegion) -> NeuralMemoryTrace:
        """
        Form a new memory by activating nodes with a specific pattern
        The pattern becomes the "memory" - similar to an image in visual cortex
        """
        memory_nodes = []
        activation_patterns = []
       
        # Activate nodes in target region
        for node in self.node_by_region[region]:
            # Map stimulus pattern to node activation
            idx = hash(node.node_id) % len(stimulus_pattern)
            activation = node.activate(stimulus_pattern[idx] if idx < len(stimulus_pattern) else 0.5)
           
            if activation > 0.3:  # Node fired
                memory_nodes.append(node)
                activation_patterns.append(activation)
       
        # Calculate memory strength (how many nodes activated)
        strength = len(memory_nodes) / len(self.node_by_region[region])
       
        # Create memory trace from activation patterns
        pattern_array = np.array(activation_patterns[:100]) if activation_patterns else np.zeros(100)
       
        # Store memory in each activated node
        memories = []
        for node in memory_nodes[:100]:  # Limit for performance
            memory = node.store_memory(pattern_array, strength)
            memories.append(memory)
       
        # Create composite memory
        composite_memory = NeuralMemoryTrace(
            memory_id=hashlib.sha256(f"composite_{time.time()}".encode()).hexdigest()[:16],
            timestamp=time.time(),
            activated_nodes=[m.node_id for m in memories],
            activation_pattern=pattern_array,
            strength=strength,
            region=region,
            rf_signature=hashlib.sha256(str(strength).encode()).hexdigest()[:16]
        )
       
        self.active_memories.append(composite_memory)
       
        return composite_memory
   
    def recall_memory(self, memory_id: str) -> Optional[np.ndarray]:
        """Recall a stored memory pattern"""
        for memory in self.active_memories:
            if memory.memory_id == memory_id:
                return memory.activation_pattern
        return None
   
    def get_activation_rf_signals(self) -> Dict[str, float]:
        """
        Convert node activations to RF signals for transmission
        Each node's activation modulates its RF frequency
        """
        rf_signals = {}
        for node in self.nodes.values():
            if node.activation_state > 0.1:
                # Frequency modulation: base_freq + (activation_state * deviation)
                modulated_freq = node.rf_frequency + (node.activation_state * 0.05)
                rf_signals[node.node_id] = modulated_freq
        return rf_signals


