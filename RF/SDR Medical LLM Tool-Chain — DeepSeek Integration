@dataclass
class SensorReading:
    device_id: str
    timestamp: str
    channel: int
    sample_rate_hz: float
    duration_ms: float
    signal_raw: list[float]
    unit: str = "µV"
    metadata: dict = field(default_factory=dict)

@dataclass
class SpectralResult:
    freqs: list[float]
    psd: list[float]
    bands: dict[str, float]       # delta/theta/alpha/beta/gamma power
    peak_freq: float
    snr_db: float

@dataclass
class FilterResult:
    filter_type: str
    cutoff_hz: list[float]
    order: int
    signal_filtered: list[float]
    rms_before: float
    rms_after: float

@dataclass
class AnomalyReport:
    detected: bool
    anomaly_type: str
    confidence: float
    segments: list[dict]
    recommendation: str

