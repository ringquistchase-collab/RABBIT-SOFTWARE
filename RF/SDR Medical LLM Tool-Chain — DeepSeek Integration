# TOOL REGISTRY  — these become DeepSeek function-calling tools
# ══════════════════════════════════════════════════════════════════════════════

class ToolRegistry:
    def __init__(self, hardware: SDRHardware, processor: SignalProcessor):
        self.hw   = hardware
        self.proc = processor
        self._last_reading: Optional[SensorReading] = None

    # ── Tool schemas (OpenAI function format) ──────────────────────────────────
    @property
    def schemas(self) -> list[dict]:
        return [
            {
                "type": "function",
                "function": {
                    "name": "read_sensor",
                    "description": "Read live RF/SDR signal from a hardware channel.",
                    "parameters": {
                        "type": "object",
                        "properties": {
                            "channel":     {"type": "integer", "description": "Channel 0–15"},
                            "duration_ms": {"type": "number",  "description": "Duration in ms (100–10000)"},
                        },
                        "required": ["channel", "duration_ms"],
                    },
                },
            },
            {
                "type": "function",
                "function": {
                    "name": "run_fft",
                    "description": "Run FFT spectral analysis on the last or specified reading.",
                    "parameters": {
                        "type": "object",
                        "properties": {
                            "channel": {"type": "integer", "description": "Channel to analyse (uses last reading if omitted)"},
                        },
                    },
                },
            },
            {
                "type": "function",
                "function": {
                    "name": "apply_bandpass",
                    "description": "Apply Butterworth bandpass filter.",
                    "parameters": {
                        "type": "object",
                        "properties": {
                            "low_hz":  {"type": "number", "description": "Lower cutoff frequency"},
                            "high_hz": {"type": "number", "description": "Upper cutoff frequency"},
                            "order":   {"type": "integer", "description": "Filter order (default 4)"},
                        },
                        "required": ["low_hz", "high_hz"],
                    },
                },
            },
            {
                "type": "function",
                "function": {
                    "name": "apply_notch",
                    "description": "Apply notch filter to suppress mains interference.",
                    "parameters": {
                        "type": "object",
                        "properties": {
                            "notch_hz": {"type": "number", "description": "Notch frequency (50 or 60 Hz)"},
                            "q_factor": {"type": "number", "description": "Quality factor (default 30)"},
                        },
                        "required": ["notch_hz"],
                    },
                },
            },
            {
                "type": "function",
                "function": {
                    "name": "detect_anomalies",
                    "description": "Detect spike artifacts or anomalies in the last reading.",
                    "parameters": {"type": "object", "properties": {}},
                },
            },
            {
                "type": "function",
                "function": {
                    "name": "check_impedance",
                    "description": "Check electrode impedance for a channel.",
                    "parameters": {
                        "type": "object",
                        "properties": {
                            "channel": {"type": "integer"},
                        },
                        "required": ["channel"],
                    },
                },
            },
            {
                "type": "function",
                "function": {
                    "name": "set_hardware_gain",
                    "description": "Set amplifier gain in dB.",
                    "parameters": {
                        "type": "object",
                        "properties": {
                            "gain_db": {"type": "number"},
                        },
                        "required": ["gain_db"],
                    },
                },
            },
            {
                "type": "function",
                "function": {
                    "name": "generate_report",
                    "description": "Generate a structured clinical signal report from accumulated data.",
                    "parameters": {
                        "type": "object",
                        "properties": {
                            "patient_id":  {"type": "string"},
                            "session_id":  {"type": "string"},
                            "notes":       {"type": "string"},
                        },
                        "required": ["patient_id"],
                    },
                },
            },
        ]

    # ── Tool dispatchers ───────────────────────────────────────────────────────
    def call(self, name: str, args: dict) -> dict:
        dispatch = {
            "read_sensor":       self._read_sensor,
            "run_fft":           self._run_fft,
            "apply_bandpass":    self._apply_bandpass,
            "apply_notch":       self._apply_notch,
            "detect_anomalies":  self._detect_anomalies,
            "check_impedance":   self._check_impedance,
            "set_hardware_gain": self._set_gain,
            "generate_report":   self._generate_report,
        }
        fn = dispatch.get(name)
        if fn is None:
            return {"error": f"Unknown tool: {name}"}
        try:
            return fn(**args)
        except Exception as e:
            return {"error": str(e)}

    def _read_sensor(self, channel: int, duration_ms: float) -> dict:
        reading = self.hw.read(channel, duration_ms)
        self._last_reading = reading
        return {
            "status": "ok",
            "channel": channel,
            "samples": len(reading.signal_raw),
            "sample_rate_hz": reading.sample_rate_hz,
            "duration_ms": duration_ms,
            "rms_uv": round(float(np.sqrt(np.mean(np.array(reading.signal_raw) ** 2))), 3),
            "peak_uv": round(float(np.max(np.abs(reading.signal_raw))), 3),
            "timestamp": reading.timestamp,
        }

    def _run_fft(self, channel: Optional[int] = None) -> dict:
        if self._last_reading is None:
            return {"error": "No reading available — call read_sensor first"}
        result = self.proc.fft_analysis(self._last_reading)
        return {
            "peak_freq_hz": result.peak_freq,
            "snr_db": result.snr_db,
            "band_power": result.bands,
            "dominant_band": max(result.bands, key=result.bands.get),
        }

    def _apply_bandpass(self, low_hz: float, high_hz: float, order: int = 4) -> dict:
        if self._last_reading is None:
            return {"error": "No reading available"}
        result = self.proc.bandpass_filter(self._last_reading, low_hz, high_hz, order)
        self._last_reading.signal_raw = result.signal_filtered
        return {
            "filter": result.filter_type,
            "cutoff_hz": result.cutoff_hz,
            "rms_before_uv": result.rms_before,
            "rms_after_uv": result.rms_after,
            "attenuation_db": round(20 * np.log10((result.rms_after + 1e-12) / (result.rms_before + 1e-12)), 2),
        }

    def _apply_notch(self, notch_hz: float, q_factor: float = 30.0) -> dict:
        if self._last_reading is None:
            return {"error": "No reading available"}
        result = self.proc.notch_filter(self._last_reading, notch_hz, q_factor)
        self._last_reading.signal_raw = result.signal_filtered
        return {"filter": result.filter_type, "notch_hz": notch_hz, "rms_after_uv": result.rms_after}

    def _detect_anomalies(self) -> dict:
        if self._last_reading is None:
            return {"error": "No reading available"}
        report = self.proc.detect_anomalies(self._last_reading)
        return asdict(report)

    def _check_impedance(self, channel: int) -> dict:
        return self.hw.get_impedance(channel)

    def _set_gain(self, gain_db: float) -> dict:
        return self.hw.set_gain(gain_db)

    def _generate_report(self, patient_id: str, session_id: str = "auto", notes: str = "") -> dict:
        ts = datetime.datetime.utcnow().isoformat() + "Z"
        session_id = session_id if session_id != "auto" else f"SES-{int(time.time())}"
        return {
            "report_id": f"RPT-{patient_id}-{session_id}",
            "generated_at": ts,
            "device": self.hw.device_type,
            "patient_id": patient_id,
            "session_id": session_id,
            "notes": notes,
            "last_channel": self._last_reading.channel if self._last_reading else None,
            "summary": "Signal acquisition session complete. Review attached waveforms.",
            "status": "READY_FOR_REVIEW",
        }

