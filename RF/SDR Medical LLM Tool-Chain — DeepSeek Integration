# HARDWARE ABSTRACTION LAYER  (real or simulated)
# ══════════════════════════════════════════════════════════════════════════════

class SDRHardware:
    """
    Wraps real SDR/medical device I/O.
    Supports:  serial COM port  |  USB HID  |  TCP socket  |  simulation
    """
    SUPPORTED_DEVICES = {
        "neuromind_v2":  {"channels": 8,  "sample_rate": 256,  "freq_range": [0.1, 100]},
        "neuromind_v3":  {"channels": 16, "sample_rate": 512,  "freq_range": [0.1, 150]},
        "eeg_generic":   {"channels": 32, "sample_rate": 1000, "freq_range": [0.5, 300]},
        "ecg_12lead":    {"channels": 12, "sample_rate": 500,  "freq_range": [0.05, 150]},
        "impedance_sdr": {"channels": 4,  "sample_rate": 2000, "freq_range": [1, 1000]},
    }

    def __init__(self, device_type: str = "neuromind_v2", port: Optional[str] = None):
        self.device_type = device_type
        self.port        = port
        self.spec        = self.SUPPORTED_DEVICES.get(device_type, self.SUPPORTED_DEVICES["neuromind_v2"])
        self._ser        = None
        self._connected  = False
        self._connect()

    def _connect(self):
        if self.port and HAS_SERIAL:
            try:
                self._ser = serial.Serial(self.port, baudrate=115200, timeout=1)
                self._connected = True
                console.print(f"[green]✓ Connected to {self.device_type} on {self.port}[/green]")
                return
            except Exception as e:
                console.print(f"[yellow]⚠ Serial failed ({e}) — using simulation[/yellow]")
        console.print(f"[blue]ℹ Simulation mode: {self.device_type}[/blue]")
        self._connected = False

    def read(self, channel: int, duration_ms: float) -> SensorReading:
        """Read from hardware or generate realistic simulated EEG/ECG."""
        n = int(self.spec["sample_rate"] * duration_ms / 1000)
        t = np.linspace(0, duration_ms / 1000, n)

        if self._connected and self._ser:
            raw = self._read_hardware(channel, n)
        else:
            raw = self._simulate_signal(t, channel)

        return SensorReading(
            device_id   = self.device_type,
            timestamp   = datetime.datetime.utcnow().isoformat() + "Z",
            channel     = channel,
            sample_rate_hz = self.spec["sample_rate"],
            duration_ms = duration_ms,
            signal_raw  = raw.tolist(),
            unit        = "µV",
            metadata    = {"simulated": not self._connected, "spec": self.spec},
        )

    def _read_hardware(self, channel: int, n_samples: int) -> np.ndarray:
        """Read n_samples from physical device over serial."""
        cmd = struct.pack(">BBH", 0xA5, channel, n_samples)
        self._ser.write(cmd)
        raw_bytes = self._ser.read(n_samples * 4)
        return np.frombuffer(raw_bytes, dtype=np.float32)

    def _simulate_signal(self, t: np.ndarray, channel: int) -> np.ndarray:
        """Generate realistic multi-band EEG with per-channel variation."""
        rng = np.random.default_rng(channel + int(time.time()) % 1000)
        sig = (
            15.0 * np.sin(2 * np.pi * 1.5 * t + rng.uniform(0, 2 * np.pi))  # delta
          + 10.0 * np.sin(2 * np.pi * 6.0 * t + rng.uniform(0, 2 * np.pi))  # theta
          +  8.0 * np.sin(2 * np.pi * 10.0 * t + rng.uniform(0, 2 * np.pi)) # alpha
          +  4.0 * np.sin(2 * np.pi * 20.0 * t + rng.uniform(0, 2 * np.pi)) # beta
          +  2.0 * rng.standard_normal(len(t))                                # noise
        )
        # Occasional spike artifact
        if rng.random() < 0.15:
            idx = rng.integers(0, len(t))
            sig[idx] += rng.uniform(80, 150)
        return sig

    def set_gain(self, gain_db: float) -> dict:
        if self._connected and self._ser:
            self._ser.write(struct.pack(">Bf", 0xA6, gain_db))
        return {"status": "ok", "gain_db": gain_db}

    def set_filter(self, low_hz: float, high_hz: float) -> dict:
        if self._connected and self._ser:
            self._ser.write(struct.pack(">Bff", 0xA7, low_hz, high_hz))
        return {"status": "ok", "bandpass": [low_hz, high_hz]}

    def get_impedance(self, channel: int) -> dict:
        if self._connected and self._ser:
            self._ser.write(struct.pack(">BB", 0xA8, channel))
            raw = self._ser.read(4)
            ohms = struct.unpack(">f", raw)[0]
        else:
            ohms = np.random.uniform(1000, 50000)
        quality = "GOOD" if ohms < 5000 else ("FAIR" if ohms < 20000 else "POOR")
        return {"channel": channel, "impedance_ohms": round(ohms, 1), "quality": quality}

# ══════════════════════════════════════════════════════════════════════════════
# SIGNAL PROCESSING ENGINE
# ══════════════════════════════════════════════════════════════════════════════

class SignalProcessor:
    EEG_BANDS = {
        "delta":  (0.5, 4.0),
        "theta":  (4.0, 8.0),
        "alpha":  (8.0, 13.0),
        "beta":   (13.0, 30.0),
        "gamma":  (30.0, 100.0),
    }

    @staticmethod
    def fft_analysis(reading: SensorReading) -> SpectralResult:
        sig = np.array(reading.signal_raw)
        fs  = reading.sample_rate_hz
        n   = len(sig)
        win = np.hanning(n)
        fft_vals = np.fft.rfft(sig * win)
        freqs = np.fft.rfftfreq(n, 1.0 / fs)
        psd   = (np.abs(fft_vals) ** 2) / (fs * (win ** 2).sum())

        bands = {}
        for band, (lo, hi) in SignalProcessor.EEG_BANDS.items():
            mask = (freqs >= lo) & (freqs <= hi)
            bands[band] = float(np.trapz(psd[mask], freqs[mask])) if mask.any() else 0.0

        peak_idx = np.argmax(psd[1:]) + 1
        signal_p = np.sum(psd[1:])
        noise_p  = np.mean(psd[-20:]) * len(psd)
        snr = 10 * np.log10(signal_p / (noise_p + 1e-12))

        return SpectralResult(
            freqs     = freqs[:200].tolist(),
            psd       = psd[:200].tolist(),
            bands     = {k: round(v, 4) for k, v in bands.items()},
            peak_freq = round(float(freqs[peak_idx]), 2),
            snr_db    = round(float(snr), 2),
        )

    @staticmethod
    def bandpass_filter(reading: SensorReading, low_hz: float, high_hz: float, order: int = 4) -> FilterResult:
        sig = np.array(reading.signal_raw)
        fs  = reading.sample_rate_hz
        nyq = fs / 2.0
        rms_before = float(np.sqrt(np.mean(sig ** 2)))

        if HAS_SCIPY:
            b, a = sp_signal.butter(order, [low_hz / nyq, high_hz / nyq], btype="band")
            filtered = sp_signal.filtfilt(b, a, sig)
        else:
            # Simple moving average fallback
            kernel = int(fs / ((low_hz + high_hz) / 2))
            filtered = np.convolve(sig, np.ones(kernel) / kernel, mode="same")

        return FilterResult(
            filter_type    = "butterworth_bandpass",
            cutoff_hz      = [low_hz, high_hz],
            order          = order,
            signal_filtered = filtered.tolist(),
            rms_before     = round(rms_before, 4),
            rms_after      = round(float(np.sqrt(np.mean(filtered ** 2))), 4),
        )

    @staticmethod
    def notch_filter(reading: SensorReading, notch_hz: float = 50.0, q: float = 30.0) -> FilterResult:
        sig = np.array(reading.signal_raw)
        fs  = reading.sample_rate_hz
        rms_before = float(np.sqrt(np.mean(sig ** 2)))

        if HAS_SCIPY:
            b, a = sp_signal.iirnotch(notch_hz, q, fs)
            filtered = sp_signal.filtfilt(b, a, sig)
        else:
            filtered = sig.copy()

        return FilterResult(
            filter_type    = "iir_notch",
            cutoff_hz      = [notch_hz],
            order          = 2,
            signal_filtered = filtered.tolist(),
            rms_before     = round(rms_before, 4),
            rms_after      = round(float(np.sqrt(np.mean(filtered ** 2))), 4),
        )

    @staticmethod
    def detect_anomalies(reading: SensorReading) -> AnomalyReport:
        sig   = np.array(reading.signal_raw)
        mean  = np.mean(sig)
        std   = np.std(sig)
        threshold = mean + 4.5 * std
        spike_mask = np.abs(sig - mean) > threshold
        spike_indices = np.where(spike_mask)[0]

        segments = []
        for idx in spike_indices[:10]:
            segments.append({
                "sample_index": int(idx),
                "time_ms": round(idx / reading.sample_rate_hz * 1000, 1),
                "amplitude_uv": round(float(sig[idx]), 2),
            })

        detected = len(spike_indices) > 0
        return AnomalyReport(
            detected      = detected,
            anomaly_type  = "spike_artifact" if detected else "none",
            confidence    = min(0.95, len(spike_indices) / 5.0) if detected else 0.0,
            segments      = segments,
            recommendation = (
                "Review artifacts — consider electrode impedance check."
                if detected else "Signal quality nominal."
            ),
        )

