# DEEPSEEK AGENT  — agentic loop with tool-calling
# ══════════════════════════════════════════════════════════════════════════════

class DeepSeekAgent:
    def __init__(self, registry: ToolRegistry, api_key: str = DEEPSEEK_API_KEY):
        self.registry = registry
        self.history: list[dict] = []

        if HAS_OPENAI:
            self.client = OpenAI(api_key=api_key, base_url=DEEPSEEK_BASE_URL)
        else:
            self.client = None

    def chat(self, user_message: str, max_tool_rounds: int = 8) -> str:
        """
        Send a message and run the agentic tool-call loop.
        Returns the final text response.
        """
        self.history.append({"role": "user", "content": user_message})

        messages = [{"role": "system", "content": SYSTEM_PROMPT}] + self.history

        for round_num in range(max_tool_rounds):
            if self.client is None:
                # Simulation fallback
                response_text = self._simulate_response(user_message)
                self.history.append({"role": "assistant", "content": response_text})
                return response_text

            response = self.client.chat.completions.create(
                model   = DEEPSEEK_MODEL,
                messages = messages,
                tools   = self.registry.schemas,
                tool_choice = "auto",
            )
            msg = response.choices[0].message

            # No tool call → done
            if not msg.tool_calls:
                text = msg.content or ""
                self.history.append({"role": "assistant", "content": text})
                return text

            # Execute tool calls
            messages.append(msg)
            for tc in msg.tool_calls:
                args = json.loads(tc.function.arguments)
                console.print(f"  [cyan]⚙ Tool: {tc.function.name}({args})[/cyan]")
                result = self.registry.call(tc.function.name, args)
                console.print(f"  [green]  → {result}[/green]")
                messages.append({
                    "role": "tool",
                    "tool_call_id": tc.id,
                    "content": json.dumps(result),
                })

        return "[max tool rounds reached]"

    def _simulate_response(self, msg: str) -> str:
        """Return a simulated response when openai package is unavailable."""
        return (
            f"[SIMULATION] DeepSeek response to: '{msg}'\n"
            "Install openai package and set DEEPSEEK_API_KEY for real responses.\n"
            "Tools available: " + ", ".join(s["function"]["name"] for s in self.registry.schemas)
        )

    def reset(self):
        self.history.clear()

