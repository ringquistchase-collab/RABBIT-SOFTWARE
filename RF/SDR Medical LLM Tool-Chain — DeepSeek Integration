# WebSocket SERVER  — expose agent over network for web UI
# ══════════════════════════════════════════════════════════════════════════════

async def websocket_server(agent: DeepSeekAgent, host: str = "0.0.0.0", port: int = 8765):
    try:
        import websockets
    except ImportError:
        print("pip install websockets  to enable server mode")
        return

    async def handler(ws):
        console.print(f"[green]WS client connected: {ws.remote_address}[/green]")
        async for raw in ws:
            try:
                pkt = json.loads(raw)
                cmd = pkt.get("cmd", "chat")

                if cmd == "chat":
                    reply = agent.chat(pkt["message"])
                    await ws.send(json.dumps({"type": "reply", "text": reply}))

                elif cmd == "read_sensor":
                    result = agent.registry.call("read_sensor", pkt.get("args", {}))
                    await ws.send(json.dumps({"type": "sensor", "data": result}))

                elif cmd == "reset":
                    agent.reset()
                    await ws.send(json.dumps({"type": "ok", "message": "Session reset"}))

                else:
                    await ws.send(json.dumps({"type": "error", "message": f"Unknown cmd: {cmd}"}))

            except Exception as e:
                await ws.send(json.dumps({"type": "error", "message": str(e)}))

    async with websockets.serve(handler, host, port):
        console.print(f"[bold green]WS server running on ws://{host}:{port}[/bold green]")
        await asyncio.Future()   # run forever

# ══════════════════════════════════════════════════════════════════════════════
# CLI  — interactive terminal session
# ══════════════════════════════════════════════════════════════════════════════

def run_cli(agent: DeepSeekAgent):
    console.rule("[bold]RF/SDR Medical LLM Tool-Chain — DeepSeek[/bold]")
    console.print("Type a command or question. 'quit' to exit. 'reset' to clear session.\n")

    # Quick-start examples
    examples = [
        "Read 2 seconds from channel 0 and run FFT analysis",
        "Apply a 1–40 Hz bandpass filter then detect any anomalies",
        "Check electrode impedance on channels 0 through 3",
        "Generate a session report for patient P-001",
        "What is the dominant EEG band in the last reading?",
    ]
    console.print("[dim]Example prompts:[/dim]")
    for i, ex in enumerate(examples, 1):
        console.print(f"  [dim]{i}. {ex}[/dim]")
    console.print()

    while True:
        try:
            user_in = input("You: ").strip()
        except (EOFError, KeyboardInterrupt):
            break

        if not user_in:
            continue
        if user_in.lower() in ("quit", "exit", "q"):
            break
        if user_in.lower() == "reset":
            agent.reset()
            console.print("[yellow]Session reset.[/yellow]")
            continue
        if user_in.isdigit() and 1 <= int(user_in) <= len(examples):
            user_in = examples[int(user_in) - 1]
            console.print(f"[dim]→ {user_in}[/dim]")

        console.print()
        reply = agent.chat(user_in)
        console.print(f"\n[bold]Agent:[/bold] {reply}\n")
        console.rule()

# ══════════════════════════════════════════════════════════════════════════════
# ENTRY POINT
# ══════════════════════════════════════════════════════════════════════════════

def main():
    parser = argparse.ArgumentParser(description="RF/SDR Medical LLM Tool-Chain")
    parser.add_argument("--mode",   choices=["cli", "server"], default="cli")
    parser.add_argument("--device", default="neuromind_v2",
                        choices=list(SDRHardware.SUPPORTED_DEVICES.keys()))
    parser.add_argument("--port",   type=str, default=None,
                        help="Serial port (e.g. /dev/ttyUSB0 or COM3)")
    parser.add_argument("--ws-port", type=int, default=8765)
    parser.add_argument("--api-key", default=DEEPSEEK_API_KEY)
    args = parser.parse_args()

    hw       = SDRHardware(device_type=args.device, port=args.port)
    proc     = SignalProcessor()
    registry = ToolRegistry(hw, proc)
    agent    = DeepSeekAgent(registry, api_key=args.api_key)

    if args.mode == "server":
        asyncio.run(websocket_server(agent, port=args.ws_port))
    else:
        run_cli(agent)

if __name__ == "__main__":
    main()
