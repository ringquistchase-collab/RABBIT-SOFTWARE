⚡ 1. ONE-COMMAND BOOTSTRAP SCRIPT (CORE)

#!/bin/bash

set -e

CLOUD=$1

echo "🚀 RabbitOS Enterprise Bootstrap Starting..."
echo "☁️ Target Cloud: $CLOUD"

if [ "$CLOUD" == "aws" ]; then
    echo "📦 Installing dependencies..."
    ./scripts/install_helm.sh

    echo "🏗️ Provisioning infrastructure (Terraform)..."
    cd terraform/aws
    terraform init
    terraform apply -auto-approve

    echo "☸️ Configuring Kubernetes access..."
    aws eks update-kubeconfig --name rabbitos-prod

    echo "📊 Deploying Kubernetes stack..."
    cd ../../scripts
    ./deploy_k8s.sh

    echo "🌐 Configuring DNS & ingress..."
    ./configure_dns.sh

    echo "✅ Verifying cluster..."
    ./verify_cluster.sh

    echo "🎉 RabbitOS Enterprise is LIVE"
fi


