🔄 7. CI/CD PIPELINE (FULL AUTO DEPLOY)

name: Deploy RabbitOS

on:
  push:
    branches: [ "main" ]

jobs:
  deploy:
    runs-on: ubuntu-latest

    steps:
      - uses: actions/checkout@v3

      - name: Install Terraform
        run: sudo apt-get install terraform

      - name: Deploy Infra
        run: |
          cd terraform/aws
          terraform init
          terraform apply -auto-approve

      - name: Deploy Kubernetes Apps
        run: ./scripts/deploy_k8s.sh


