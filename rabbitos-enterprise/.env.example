# AWS
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Cluster
CLUSTER_NAME=rabbitos-enterprise
ENV=prod

# Services
GATEWAY_PORT=8080
ORCHESTRATOR_PORT=8081
WORKER_CONCURRENCY=4

# LLM
LLM_PROVIDER=deepseek          # deepseek | openai | local
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
LOCAL_MODEL_PATH=/models/phi-2

# Kafka
KAFKA_BROKERS=kafka:9092
KAFKA_TOPIC_TASKS=rabbitos.tasks
KAFKA_TOPIC_RESULTS=rabbitos.results
KAFKA_CONSUMER_GROUP=rabbitos-workers

# Vector memory (Qdrant)
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=rabbitos_memory

# Graph memory (Neo4j)
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Cold storage
S3_BUCKET=rabbitos-cold-storage
S3_REGION=us-east-1

# Supabase (existing RabbitOS backend)
SUPABASE_URL=https://ludxbakxpmdqhfgdenwp.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Auth
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRY_SECONDS=3600

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
LOG_LEVEL=INFO
