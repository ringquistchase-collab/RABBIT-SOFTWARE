# SECTION 1: BIOLOGICAL STORAGE LIMITS (Theoretical Maximum)
# =============================================================================

class BiologicalStorageCalculator:
    """
    Calculates storage capacity based on biological neuron equivalents
    Each synthetic node mimics a cluster of biological neurons
    """
    
    # Biological constants
    HUMAN_NEURONS = 86_000_000_000  # 86 billion
    SYNAPSES_PER_NEURON = 7_000      # Average connections per neuron
    BITS_PER_SYNAPSE = 4.7           # Estimated information per synapse (Hebbian)
    
    # Human brain total storage (theoretical)
    HUMAN_BRAIN_BITS = HUMAN_NEURONS * SYNAPSES_PER_NEURON * BITS_PER_SYNAPSE
    HUMAN_BRAIN_BYTES = HUMAN_BRAIN_BITS / 8
    HUMAN_BRAIN_GB = HUMAN_BRAIN_BYTES / (1024**3)
    
    @classmethod
    def calculate_neuron_cluster_capacity(cls, neurons_per_node: int) -> Dict:
        """
        Calculate storage for a node that mimics N biological neurons
        """
        # Each neuron in the cluster contributes synaptic storage
        total_synapses = neurons_per_node * cls.SYNAPSES_PER_NEURON
        storage_bits = total_synapses * cls.BITS_PER_SYNAPSE
        storage_bytes = storage_bits / 8
        storage_gb = storage_bytes / (1024**3)
        
        # Plasticity factor (how much can be rewired)
        plasticity_bytes = storage_bytes * 0.3  # 30% plasticity
        
        return {
            'neurons_in_cluster': neurons_per_node,
            'total_synapses': total_synapses,
            'theoretical_bits': storage_bits,
            'theoretical_bytes': storage_bytes,
            'theoretical_gb': storage_gb,
            'plasticity_capacity_gb': plasticity_bytes / (1024**3),
            'equivalent_percent_of_human_brain': (neurons_per_node / cls.HUMAN_NEURONS) * 100
        }


# =============================================================================
# SECTION 2: RF NODE STORAGE CAPACITY (Technical)
# =============================================================================

class RFNodeStorageCalculator:
    """
    Calculates storage for RF-tuned nodes based on:
    - Frequency bandwidth
    - Sampling rate
    - Temporal resolution
    - Pattern storage density
    """
    
    # RF parameters
    FREQUENCY_BAND_GHZ = 1.0           # 1 GHz bandwidth per node
    SAMPLING_RATE_GHZ = 2.0            # 2 GHz sampling (Nyquist)
    BITS_PER_SAMPLE = 16               # 16-bit ADC resolution
    
    # Storage per second of RF capture
    RF_BYTES_PER_SECOND = (SAMPLING_RATE_GHZ * 1e9) * (BITS_PER_SAMPLE / 8)
    
    # Pattern storage efficiency
    PATTERNS_PER_GHZ = 1000            # unique patterns per GHz of bandwidth
    BITS_PER_PATTERN = 1024            # 1 KB per pattern (compressed)
    
    @classmethod
    def calculate_node_capacity(cls, hours_active: float = 24 * 365) -> Dict:
        """
        Calculate storage for a single RF-tuned node
        hours_active = total operational hours (default 1 year)
        """
        seconds_active = hours_active * 3600
        
        # RF signal storage
        rf_storage_bytes = cls.RF_BYTES_PER_SECOND * seconds_active
        
        # Pattern storage
        total_patterns = cls.PATTERNS_PER_GHZ * cls.FREQUENCY_BAND_GHZ
        pattern_storage_bytes = total_patterns * (cls.BITS_PER_PATTERN / 8)
        
        # Metadata overhead
        metadata_bytes = pattern_storage_bytes * 0.1  # 10% overhead
        
        total_bytes = rf_storage_bytes + pattern_storage_bytes + metadata_bytes
        total_gb = total_bytes / (1024**3)
        total_tb = total_bytes / (1024**4)
        
        return {
            'rf_signal_storage_gb': rf_storage_bytes / (1024**3),
            'pattern_storage_gb': pattern_storage_bytes / (1024**3),
            'metadata_overhead_gb': metadata_bytes / (1024**3),
            'total_storage_gb': total_gb,
            'total_storage_tb': total_tb,
            'hours_active': hours_active,
            'days_active': hours_active / 24,
            'patterns_stored': total_patterns
        }


# =============================================================================
# SECTION 3: NEURAL HUB STORAGE (Connected Nodes)
# =============================================================================

class NeuralHubStorageCalculator:
    """
    Calculates storage when multiple nodes form a hub/network
    Hub benefits:
    - Distributed storage (redundancy)
    - Collective memory (emergent patterns)
    - Cross-node encoding (higher density)
    """
    
    @classmethod
    def calculate_hub_capacity(cls, num_nodes: int, 
                               storage_per_node_gb: float,
                               redundancy_factor: float = 1.5) -> Dict:
        """
        Calculate total hub storage with redundancy
        redundancy_factor = 1.0 = no redundancy, 2.0 = double redundancy
        """
        total_raw_gb = num_nodes * storage_per_node_gb
        usable_gb = total_raw_gb / redundancy_factor
        
        # Hub benefits (emergent patterns, compression)
        compression_gain = 1.2  # 20% better compression in hub
        effective_gb = usable_gb * compression_gain
        
        # Cross-node encoding (patterns distributed across nodes)
        encoding_efficiency = 1.15  # 15% more efficient
        
        final_gb = effective_gb * encoding_efficiency
        
        return {
            'num_nodes': num_nodes,
            'storage_per_node_gb': storage_per_node_gb,
            'total_raw_capacity_gb': total_raw_gb,
            'redundancy_factor': redundancy_factor,
            'usable_capacity_gb': usable_gb,
            'compression_gain_percent': (compression_gain - 1) * 100,
            'encoding_efficiency_percent': (encoding_efficiency - 1) * 100,
            'effective_capacity_gb': final_gb,
            'effective_capacity_tb': final_gb / 1024,
            'effective_capacity_pb': final_gb / (1024**2)
        }


