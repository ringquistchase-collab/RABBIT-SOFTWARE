class NeuralHubSpec:
    """
    Storage specification for a hub of connected nodes
    Hubs have emergent properties - more than sum of parts
    """
    
    def __init__(self, num_nodes: int, node_spec: CompleteNodeSpec):
        self.num_nodes = num_nodes
        self.node_spec = node_spec
        
        # Calculate base storage
        self.total_raw_gb = num_nodes * node_spec.rf_storage_gb
        
        # Hub benefits (emergent properties)
        self.emergent_compression_factor = 1.25  # 25% better compression
        self.distributed_encoding_factor = 1.15  # 15% more efficient
        self.redundancy_factor = 1.5  # 50% redundancy for safety
        
        # Effective storage
        self.effective_gb = (self.total_raw_gb / self.redundancy_factor) * \
                           self.emergent_compression_factor * \
                           self.distributed_encoding_factor
        
        # Memory storage in hub
        self.hub_memory_capacity = self._calculate_hub_memories()
    
    def _calculate_hub_memories(self) -> Dict:
        """Calculate collective memory capacity of hub"""
        return {
            'short_term': self.node_spec.short_term_memories * self.num_nodes * 0.8,
            'long_term': self.node_spec.long_term_memories * self.num_nodes * 0.6,
            'procedural': self.node_spec.procedural_memories * self.num_nodes * 0.7,
            'episodic': self.node_spec.episodic_memories * self.num_nodes * 0.5
        }
    
    def get_specification(self) -> Dict:
        """Get complete hub specification"""
        return {
            'num_nodes': self.num_nodes,
            'total_raw_capacity_gb': self.total_raw_gb,
            'total_raw_capacity_tb': self.total_raw_gb / 1024,
            'effective_capacity_gb': self.effective_gb,
            'effective_capacity_tb': self.effective_gb / 1024,
            'effective_capacity_pb': self.effective_gb / (1024**2),
            'redundancy_factor': self.redundancy_factor,
            'emergent_compression_gain': f"{int((self.emergent_compression_factor-1)*100)}%",
            'distributed_encoding_gain': f"{int((self.distributed_encoding_factor-1)*100)}%",
            'hub_memories': self.hub_memory_capacity,
            'equivalent_human_brain_percent': (self.effective_gb / 2.5) * 100  # Human brain ~2.5 PB theoretical
        }


