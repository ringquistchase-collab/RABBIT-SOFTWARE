# SECTION 5: CHEMICAL STATE STORAGE
# =============================================================================

class ChemicalStateStorage:
    """
    Storage for neurotransmitter and chemical state history
    Each state change is recorded with timestamp and concentration
    """
    
    # Neurotransmitter tracking
    NEUROTRANSMITTERS = [
        'dopamine', 'serotonin', 'acetylcholine', 'GABA', 'glutamate',
        'norepinephrine', 'endorphin', 'oxytocin', 'cortisol', 'melatonin'
    ]
    
    # Storage per state (floats + metadata)
    BYTES_PER_STATE = len(NEUROTRANSMITTERS) * 8  # 8 bytes per float
    BYTES_PER_TIMESTAMP = 8
    BYTES_PER_METADATA = 32
    
    TOTAL_BYTES_PER_RECORD = BYTES_PER_STATE + BYTES_PER_TIMESTAMP + BYTES_PER_METADATA
    
    @classmethod
    def calculate_chemical_storage(cls, node_capacity_gb: float, 
                                   record_rate_hz: float = 1.0) -> Dict:
        """
        Calculate how much chemical history can be stored
        record_rate_hz = how many state recordings per second
        """
        records_per_second = record_rate_hz
        records_per_day = records_per_second * 86400
        records_per_year = records_per_day * 365
        
        # Storage per time period
        bytes_per_day = records_per_day * cls.TOTAL_BYTES_PER_RECORD
        bytes_per_year = records_per_year * cls.TOTAL_BYTES_PER_RECORD
        
        # How many years fit in node capacity
        years_of_history = (node_capacity_gb * (1024**3)) / bytes_per_year if bytes_per_year > 0 else 0
        
        return {
            'bytes_per_record': cls.TOTAL_BYTES_PER_RECORD,
            'neurotransmitters_tracked': len(cls.NEUROTRANSMITTERS),
            'records_per_second': records_per_second,
            'records_per_day': records_per_day,
            'storage_per_day_gb': bytes_per_day / (1024**3),
            'storage_per_year_gb': bytes_per_year / (1024**3),
            'years_of_history': years_of_history
        }


