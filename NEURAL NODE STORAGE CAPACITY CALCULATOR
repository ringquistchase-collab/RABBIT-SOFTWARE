@dataclass
class CompleteNodeSpec:
    """Complete storage specification for a tuned neural node"""
    
    # Node identification
    node_id: str
    node_type: str  # 'biological_mimic', 'rf_hub', 'hybrid'
    
    # Core capacities (in GB)
    biological_equivalent_gb: float
    rf_storage_gb: float
    pattern_storage_gb: float
    chemical_history_gb: float
    
    # Memory capacities
    short_term_memories: int
    long_term_memories: int
    procedural_memories: int
    episodic_memories: int
    
    # Operational limits
    max_concurrent_tasks: int
    rf_bandwidth_ghz: float
    power_consumption_w: float
    
    @classmethod
    def create_node_spec(cls, node_id: str, node_type: str, 
                         neurons_per_cluster: int = 1_000_000,
                         hours_active: float = 24 * 365) -> 'CompleteNodeSpec':
        """
        Create complete node specification based on parameters
        """
        # Calculate biological equivalent
        bio = BiologicalStorageCalculator.calculate_neuron_cluster_capacity(neurons_per_cluster)
        
        # Calculate RF storage
        rf = RFNodeStorageCalculator.calculate_node_capacity(hours_active)
        
        # Calculate chemical storage (assuming 1 recording per second)
        chem = ChemicalStateStorage.calculate_chemical_storage(rf['total_storage_gb'], 1.0)
        
        # Calculate memory capacities
        mem = MemoryTraceStorage.calculate_memory_capacity(rf['total_storage_gb'])
        
        return cls(
            node_id=node_id,
            node_type=node_type,
            biological_equivalent_gb=bio['theoretical_gb'],
            rf_storage_gb=rf['total_storage_gb'],
            pattern_storage_gb=rf['pattern_storage_gb'],
            chemical_history_gb=chem['storage_per_year_gb'],
            short_term_memories=mem.get('short_term', {}).get('memories_per_node', 0),
            long_term_memories=mem.get('long_term', {}).get('memories_per_node', 0),
            procedural_memories=mem.get('procedural', {}).get('memories_per_node', 0),
            episodic_memories=mem.get('episodic', {}).get('memories_per_node', 0),
            max_concurrent_tasks=10,
            rf_bandwidth_ghz=1.0,
            power_consumption_w=0.5
        )


