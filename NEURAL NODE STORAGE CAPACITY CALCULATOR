class MemoryTraceStorage:
    """
    Storage required for different types of memory traces
    Each memory trace is stored across multiple nodes
    """
    
    # Memory types and their storage requirements
    MEMORY_TYPES = {
        'short_term': {'bytes': 1024, 'nodes_required': 3, 'duration_hours': 24},
        'long_term': {'bytes': 10240, 'nodes_required': 10, 'duration_years': 50},
        'procedural': {'bytes': 5120, 'nodes_required': 7, 'duration_years': 30},
        'episodic': {'bytes': 20480, 'nodes_required': 15, 'duration_years': 40},
        'semantic': {'bytes': 8192, 'nodes_required': 8, 'duration_years': 60},
        'emotional': {'bytes': 4096, 'nodes_required': 5, 'duration_years': 20},
    }
    
    @classmethod
    def calculate_memory_capacity(cls, node_capacity_gb: float) -> Dict:
        """
        Calculate how many memories can be stored in a node hub
        """
        results = {}
        
        for memory_type, params in cls.MEMORY_TYPES.items():
            memory_bytes = params['bytes']
            nodes_required = params['nodes_required']
            
            # Effective memory size (distributed across nodes)
            storage_per_memory_gb = (memory_bytes * nodes_required) / (1024**3)
            
            # Number of memories this node can store
            memories_per_node = node_capacity_gb / storage_per_memory_gb if storage_per_memory_gb > 0 else 0
            
            results[memory_type] = {
                'size_per_memory_kb': memory_bytes / 1024,
                'nodes_required': nodes_required,
                'distributed_size_gb': storage_per_memory_gb,
                'memories_per_node': int(memories_per_node),
                'duration': params.get('duration_years', params.get('duration_hours', 0))
            }
        
        return results


