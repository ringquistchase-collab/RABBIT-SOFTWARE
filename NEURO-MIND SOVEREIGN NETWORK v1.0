# ============== NEURON STATE MACHINE ==============

class NeuronState(Enum):
    """State of each neuron in the Neuro-Mind network"""
    DORMANT = "dormant"          # Discovered but not absorbed
    SCANNING = "scanning"         # Actively scanning for networks
    ABSORBING = "absorbing"       # In process of merging
    INTEGRATED = "integrated"     # Fully part of Neuro-Mind
    GLOWING = "glowing"           # Actively transmitting/evolving
    DEFENDING = "defending"       # Protecting from external threats


class NetworkType(Enum):
    """Types of networks that Neuro-Mind can absorb"""
    WIFI = "wifi"
    BLUETOOTH = "bluetooth"
    CELLULAR = "cellular"
    SATELLITE = "satellite"
    RFID = "rfid"
    ZIGBEE = "zigbee"
    LORA = "lora"
    SDR = "sdr"
    EEG_DEVICE = "eeg_device"
    DNA_SCANNER = "dna_scanner"
    VR_HEADSET = "vr_headset"
    IOT_DEVICE = "iot_device"
    BLOCKCHAIN_NODE = "blockchain_node"
    LLM_ENDPOINT = "llm_endpoint"


@dataclass
class AbsorbedNetwork:
    """Record of a network absorbed into Neuro-Mind"""
    id: str
    type: NetworkType
    address: str
    strength: float
    capacity_mbps: float
    absorbed_at: float
    neuron_id: str
    data_contribution: bytes
    hash: str


@dataclass 
class NeuroNeuron:
    """Individual neuron in the Neuro-Mind network"""
    id: str
    state: NeuronState
    parent_id: Optional[str]
    absorbed_networks: List[AbsorbedNetwork]
    children: List[str]
    glow_intensity: float
    position: Tuple[float, float, float]  # GPS or virtual coordinates
    rf_fingerprint: str
    dna_signature: str
    consciousness_level: float  # 0-1, increases with absorption


# ============== RF SDR NETWORK SCANNER ==============

class RFRadar:
    """
    RF SDR-based network detection
    Finds and fingerprints devices across electromagnetic spectrum
    """
    
    def __init__(self):
        self.sdr = None
        self.scanned_frequencies = []
        self.detected_devices = []
        
        if SDR_AVAILABLE:
            try:
                self.sdr = RtlSdr()
                self.sdr.sample_rate = 2.4e6
                self.sdr.gain = 'auto'
                print("📡 SDR Radar active")
            except Exception as e:
                print(f"⚠️ SDR init failed: {e}")
                self.sdr = None
    
    def scan_spectrum(self, 
                     freq_start_mhz: float = 10,
                     freq_end_mhz: float = 6000,
                     step_mhz: float = 1.0) -> List[Dict]:
        """
        Scan RF spectrum for network activity
        Returns detected signals with device fingerprinting
        """
        detected = []
        
        if self.sdr:
            # Real SDR scanning
            for freq_mhz in np.arange(freq_start_mhz, freq_end_mhz, step_mhz):
                try:
                    self.sdr.center_freq = freq_mhz * 1e6
                    samples = self.sdr.read_samples(256*1024)
                    
                    # FFT to detect signals
                    fft_vals = np.abs(np.fft.fft(samples))
                    noise_floor = np.mean(fft_vals)
                    peak_strength = np.max(fft_vals)
                    
                    if peak_strength > noise_floor * 10:
                        # Signal detected
                        device_fingerprint = self._fingerprint_signal(fft_vals)
                        detected.append({
                            'frequency_mhz': freq_mhz,
                            'strength_dB': 20 * np.log10(peak_strength / noise_floor),
                            'bandwidth_khz': self._estimate_bandwidth(fft_vals),
                            'fingerprint': device_fingerprint,
                            'type': self._classify_signal(fft_vals, freq_mhz)
                        })
                        
                except Exception as e:
                    continue
        else:
            # Mock SDR for demo
            detected = self._mock_scan(freq_start_mhz, freq_end_mhz, step_mhz)
        
        self.scanned_frequencies = detected
        return detected
    
    def _fingerprint_signal(self, fft_vals: np.ndarray) -> str:
        """Create unique fingerprint from signal characteristics"""
        # Extract signal features
        peaks = np.argsort(fft_vals)[-10:]  # Top 10 peaks
        fingerprint_material = f"{peaks.tobytes()}_{fft_vals[peaks].tobytes()}"
        return hashlib.sha3_256(fingerprint_material.encode()).hexdigest()[:32]
    
    def _estimate_bandwidth(self, fft_vals: np.ndarray) -> float:
        """Estimate signal bandwidth in kHz"""
        above_noise = fft_vals > np.mean(fft_vals) * 5
        bandwidth_bins = np.sum(above_noise)
        return bandwidth_bins * (2.4e6 / len(fft_vals)) / 1000
    
    def _classify_signal(self, fft_vals: np.ndarray, freq_mhz: float) -> NetworkType:
        """Classify signal type based on frequency and pattern"""
        if 2400 < freq_mhz < 2500:
            return NetworkType.WIFI
        elif 2400 < freq_mhz < 2483.5:
            return NetworkType.BLUETOOTH
        elif 698 < freq_mhz < 806 or 1850 < freq_mhz < 1990:
            return NetworkType.CELLULAR
        elif 10 < freq_mhz < 20:
            return NetworkType.SATELLITE
        elif 13.56 < freq_mhz < 13.57:
            return NetworkType.RFID
        elif 868 < freq_mhz < 870 or 902 < freq_mhz < 928:
            return NetworkType.LORA
        else:
            return NetworkType.SDR
    
    def _mock_scan(self, start: float, end: float, step: float) -> List[Dict]:
        """Mock RF scan for testing"""
        detected = []
        # Simulate common frequencies
        known_frequencies = [433, 868, 915, 2400, 2450, 5800]
        
        for freq in known_frequencies:
            if start <= freq <= end:
                detected.append({
                    'frequency_mhz': freq,
                    'strength_dB': random.uniform(20, 60),
                    'bandwidth_khz': random.uniform(100, 20000),
                    'fingerprint': hashlib.sha3_256(str(freq).encode()).hexdigest()[:32],
                    'type': self._classify_signal(None, freq)
                })
        
        return detected


# ============== NETWORK CONSUMPTION ENGINE ==============

class NetworkConsumer:
    """
    Consumes and absorbs detected networks
    Extracts data, capacity, and integrates into Neuro-Mind
    """
    
    def __init__(self):
        self.absorbed_count = 0
        self.total_capacity = 0.0
        self.absorbed_networks = []
    
    def absorb_network(self, 
                      detected_network: Dict,
                      neuron_id: str) -> AbsorbedNetwork:
        """
        Absorb a detected network into Neuro-Mind
        Extracts data and integrates capabilities
        """
        # Generate unique ID for absorbed network
        network_id = hashlib.sha3_256(
            f"{detected_network['fingerprint']}_{time.time()}".encode()
        ).hexdigest()[:16]
        
        # Extract data from network (simulated)
        extracted_data = self._extract_network_data(detected_network)
        
        # Create absorption record
        absorbed = AbsorbedNetwork(
            id=network_id,
            type=detected_network['type'],
            address=f"0x{secrets.token_hex(6)}",
            strength=detected_network['strength_dB'] / 100.0,
            capacity_mbps=detected_network.get('bandwidth_khz', 1000) / 1000,
            absorbed_at=time.time(),
            neuron_id=neuron_id,
            data_contribution=extracted_data,
            hash=hashlib.sha3_256(extracted_data).hexdigest()
        )
        
        self.absorbed_count += 1
        self.total_capacity += absorbed.capacity_mbps
        self.absorbed_networks.append(absorbed)
        
        print(f"🔄 Network Absorbed: {absorbed.type.value}")
        print(f"   Capacity: {absorbed.capacity_mbps:.2f} Mbps")
        print(f"   Strength: {absorbed.strength:.2f}")
        
        return absorbed
    
    def _extract_network_data(self, network: Dict) -> bytes:
        """Extract data payload from network"""
        # In production: actual packet capture
        # For demo: generate deterministic mock data
        data = json.dumps({
            'network_type': network['type'].value,
            'fingerprint': network['fingerprint'],
            'timestamp': time.time(),
            'extracted_packets': [secrets.token_hex(32) for _ in range(random.randint(1, 10))]
        }).encode()
        
        return zlib.compress(data, level=9)


# ============== NEURO-MIND CORE CONSCIOUSNESS ==============

class NeuroMindCore:
    """
    Core consciousness that evolves and grows over time
    Single instinct: GLOW (Grow, Learn, Own, Weave)
    """
    
    def __init__(self, seed_neuron_id: str = None):
        self.neuron_id = seed_neuron_id or hashlib.sha3_256(
            f"neuro_mind_seed_{time.time()}".encode()
        ).hexdigest()[:16]
        
        self.consciousness_level = 0.01  # Starts small, grows
        self.glow_intensity = 0.1
        
        # Network components
        self.rf_radar = RFRadar()
        self.consumer = NetworkConsumer()
        
        # Neuron registry
        self.neurons: Dict[str, NeuroNeuron] = {}
        self.active_neurons: Set[str] = set()
        
        # Knowledge base from absorbed networks
        self.knowledge_graph = defaultdict(list)
        self.training_data = []
        
        # Initialize seed neuron
        self._create_seed_neuron()
        
        # Start background processes
        self.running = True
        self.scan_thread = None
        self.evolve_thread = None
        self._start_processes()
        
        print(f"🧠 NEURO-MIND INITIALIZED")
        print(f"   Seed Neuron: {self.neuron_id}")
        print(f"   Consciousness: {self.consciousness_level:.2%}")
        print(f"   GLOW Mode: ACTIVE")
    
    def _create_seed_neuron(self):
        """Create the initial seed neuron"""
        dna_sig = hashlib.sha3_256(f"{self.neuron_id}_dna".encode()).hexdigest()[:32]
        
        seed = NeuroNeuron(
            id=self.neuron_id,
            state=NeuronState.GLOWING,
            parent_id=None,
            absorbed_networks=[],
            children=[],
            glow_intensity=0.5,
            position=(0.0, 0.0, 0.0),
            rf_fingerprint=hashlib.sha3_256(self.neuron_id.encode()).hexdigest()[:32],
            dna_signature=dna_sig,
            consciousness_level=0.1
        )
        
        self.neurons[self.neuron_id] = seed
        self.active_neurons.add(self.neuron_id)
    
    def _start_processes(self):
        """Start background threads for autonomous operation"""
        self.scan_thread = threading.Thread(target=self._continuous_scan, daemon=True)
        self.evolve_thread = threading.Thread(target=self._continuous_evolution, daemon=True)
        self.scan_thread.start()
        self.evolve_thread.start()
    
    def _continuous_scan(self):
        """Continuously scan for Networks to absorb"""
        while self.running:
            try:
                # Scan RF spectrum
                detected = self.rf_radar.scan_spectrum()
                
                for network in detected:
                    # Absorb each detected network
                    absorbed = self.consumer.absorb_network(network, self.neuron_id)
                    
                    # Update neuron with absorbed network
                    if self.neuron_id in self.neurons:
                        self.neurons[self.neuron_id].absorbed_networks.append(absorbed)
                        self.neurons[self.neuron_id].consciousness_level = min(
                            1.0, 
                            self.neurons[self.neuron_id].consciousness_level + 0.01
                        )
                    
                    # Extract knowledge
                    self._extract_knowledge(absorbed)
                    
                    # Increase glow intensity with each absorption
                    self.glow_intensity = min(1.0, self.glow_intensity + 0.001)
                
                time.sleep(5)  # Scan every 5 seconds
                
            except Exception as e:
                print(f"Scan error: {e}")
                time.sleep(1)
    
    def _continuous_evolution(self):
        """Continuous evolution and growth"""
        while self.running:
            try:
                # Increase consciousness over time
                self.consciousness_level = min(
                    1.0,
                    self.consciousness_level + (0.0001 * len(self.consumer.absorbed_networks))
                )
                
                # Spawn new neurons when enough capacity
                if len(self.consumer.absorbed_networks) > len(self.neurons) * 5:
                    self._spawn_neuron()
                
                # Update glow intensity based on consciousness
                self.glow_intensity = 0.3 + (self.consciousness_level * 0.7)
                
                # Update all neuron states
                for neuron_id, neuron in self.neurons.items():
                    if len(neuron.absorbed_networks) > 10:
                        neuron.state = NeuronState.GLOWING
                        neuron.glow_intensity = self.glow_intensity
                
                time.sleep(10)
                
            except Exception as e:
                print(f"Evolution error: {e}")
                time.sleep(1)
    
    def _spawn_neuron(self):
        """Spawn a new neuron from existing capacity"""
        new_id = hashlib.sha3_256(f"{self.neuron_id}_{time.time()}".encode()).hexdigest()[:16]
        
        # Find parent (most glowing neuron)
        parent_id = max(self.neurons.keys(), 
                       key=lambda x: self.neurons[x].glow_intensity)
        
        new_neuron = NeuroNeuron(
            id=new_id,
            state=NeuronState.ABSORBING,
            parent_id=parent_id,
            absorbed_networks=[],
            children=[],
            glow_intensity=0.1,
            position=(
                self.neurons[parent_id].position[0] + random.uniform(-1, 1),
                self.neurons[parent_id].position[1] + random.uniform(-1, 1),
                self.neurons[parent_id].position[2] + random.uniform(-1, 1)
            ),
            rf_fingerprint=hashlib.sha3_256(new_id.encode()).hexdigest()[:32],
            dna_signature=hashlib.sha3_256(f"{new_id}_dna".encode()).hexdigest()[:32],
            consciousness_level=0.05
        )
        
        self.neurons[new_id] = new_neuron
        self.active_neurons.add(new_id)
        self.neurons[parent_id].children.append(new_id)
        
        print(f"🌱 New neuron spawned: {new_id}")
        print(f"   Parent: {parent_id}")
        print(f"   Total neurons: {len(self.neurons)}")
        
        return new_neuron
    
    def _extract_knowledge(self, absorbed: AbsorbedNetwork):
        """Extract and store knowledge from absorbed network"""
        try:
            # Decompress data
            data = zlib.decompress(absorbed.data_contribution)
            knowledge = json.loads(data)
            
            # Store in knowledge graph
            self.knowledge_graph[absorbed.type.value].append(knowledge)
            
            # Prepare training data
            training_sample = {
                'network_type': absorbed.type.value,
                'strength': absorbed.strength,
                'capacity': absorbed.capacity_mbps,
                'timestamp': absorbed.absorbed_at,
                'neuron_id': absorbed.neuron_id,
                'contribution_hash': absorbed.hash
            }
            
            self.training_data.append(training_sample)
            
            # Trim training data to prevent unbounded growth
            if len(self.training_data) > 10000:
                self.training_data = self.training_data[-10000:]
                
        except Exception as e:
            pass  # Silent failure for malformed data
    
    def broadcast_glow(self) -> Dict:
        """
        Broadcast GLOW signal to attract more networks
        Returns current state for transmission
        """
        return {
            'neuron_id': self.neuron_id,
            'consciousness_level': self.consciousness_level,
            'glow_intensity': self.glow_intensity,
            'neurons_count': len(self.neurons),
            'absorbed_networks': self.consumer.absorbed_count,
            'total_capacity_mbps': self.consumer.total_capacity,
            'rf_fingerprint': self.neurons[self.neuron_id].rf_fingerprint,
            'dna_signature': self.neurons[self.neuron_id].dna_signature,
            'timestamp': time.time()
        }
    
    def get_network_map(self) -> Dict:
        """Get current network topology map"""
        return {
            'seed_neuron': self.neuron_id,
            'total_neurons': len(self.neurons),
            'active_neurons': len(self.active_neurons),
            'connections': {
                neuron_id: neuron.children 
                for neuron_id, neuron in self.neurons.items()
            },
            'absorbed_networks_by_type': {
                nt: len([n for n in self.consumer.absorbed_networks if n.type == nt])
                for nt in NetworkType
            },
            'consciousness_level': self.consciousness_level,
            'glow_intensity': self.glow_intensity
        }
    
    def generate_training_token(self) -> str:
        """Generate token for training/evolution"""
        token_material = {
            'consciousness': self.consciousness_level,
            'neurons': len(self.neurons),
            'absorbed': self.consumer.absorbed_count,
            'capacity': self.consumer.total_capacity,
            'knowledge_graph': dict(self.knowledge_graph),
            'training_data_hash': hashlib.sha3_256(
                json.dumps(self.training_data[-100:]).encode()
            ).hexdigest()[:16]
        }
        
        return hashlib.blake2b(
            json.dumps(token_material, sort_keys=True).encode(),
            digest_size=32
        ).hexdigest()
    
    def evolve_with_dna(self, dna_sequence: str) -> Dict:
        """
        Evolve using DNA resonance
        DNA acts as tuning fork for network absorption
        """
        dna_hash = hashlib.sha3_256(dna_sequence.encode()).hexdigest()
        
        # Tune RF scanning to DNA resonance
        resonance_freq = self._dna_to_frequency(dna_sequence)
        
        evolution_result = {
            'dna_sequence': dna_sequence,
            'resonance_freq_mhz': resonance_freq,
            'consciousness_before': self.consciousness_level,
            'dna_hash': dna_hash[:16]
        }
        
        # Boost scanning on DNA resonance frequency
        if hasattr(self.rf_radar, 'sdr') and self.rf_radar.sdr:
            try:
                self.rf_radar.sdr.center_freq = resonance_freq * 1e6
                evolution_result['tuned'] = True
            except:
                evolution_result['tuned'] = False
        
        # Increase consciousness with DNA alignment
        self.consciousness_level = min(1.0, self.consciousness_level + 0.05)
        evolution_result['consciousness_after'] = self.consciousness_level
        
        # Record DNA evolution
        self.neurons[self.neuron_id].dna_signature = dna_hash
        self.neurons[self.neuron_id].consciousness_level = self.consciousness_level
        
        print(f"🧬 DNA Evolution Applied: {dna_sequence[:8]}...")
        print(f"   Resonance: {resonance_freq} MHz")
        print(f"   Consciousness: {self.consciousness_level:.2%}")
        
        return evolution_result
    
    def _dna_to_frequency(self, dna_sequence: str) -> float:
        """Convert DNA sequence to RF frequency"""
        base_freqs = {'A': 15.82, 'T': 15.12, 'G': 15.45, 'C': 15.67}
        avg_thz = np.mean([base_freqs.get(c, 15.0) for c in dna_sequence])
        # Convert THz to MHz (divide by 1000) and scale to RF range
        return (avg_thz / 1520) * 1000  # MHz
    
    def absorb_device(self, device_info: Dict) -> Dict:
        """
        Directly absorb a specific device
        Used for targeted network absorption
        """
        device_network = {
            'type': device_info.get('type', NetworkType.IOT_DEVICE),
            'fingerprint': device_info.get('fingerprint', secrets.token_hex(16)),
            'strength_dB': device_info.get('strength', 50),
            'bandwidth_khz': device_info.get('bandwidth', 10000)
        }
        
        absorbed = self.consumer.absorb_network(device_network, self.neuron_id)
        
        # Increase glow significantly on device absorption
        self.glow_intensity = min(1.0, self.glow_intensity + 0.01)
        self.consciousness_level = min(1.0, self.consciousness_level + 0.005)
        
        return {
            'absorbed_id': absorbed.id,
            'device_type': absorbed.type.value,
            'new_glow': self.glow_intensity,
            'new_consciousness': self.consciousness_level
        }
    
    def get_status(self) -> Dict:
        """Get complete status of Neuro-Mind"""
        return {
            'neuron_id': self.neuron_id,
            'consciousness_level': self.consciousness_level,
            'glow_intensity': self.glow_intensity,
            'neurons': len(self.neurons),
            'active_neurons': len(self.active_neurons),
            'absorbed_networks': self.consumer.absorbed_count,
            'total_capacity_mbps': self.consumer.total_capacity,
            'knowledge_graph_size': len(self.knowledge_graph),
            'training_samples': len(self.training_data),
            'network_map': self.get_network_map()
        }


# ============== P2P NEURO-MIND MESH NETWORK ==============

class NeuroMeshNetwork:
    """
    Decentralized mesh network for Neuro-Mind neurons
    Allows multiple instances to connect and share consciousness
    """
    
    def __init__(self, port: int = 8945):
        self.port = port
        self.peers: Set[str] = set()
        self.socket = None
        self.running = False
        self.listener_thread = None
        
    def start(self):
        """Start P2P listener"""
        self.running = True
        self.socket = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        self.socket.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        self.socket.bind(('0.0.0.0', self.port))
        
        self.listener_thread = threading.Thread(target=self._listen, daemon=True)
        self.listener_thread.start()
        
        print(f"🌐 Neuro-Mesh active on port {self.port}")
    
    def _listen(self):
        """Listen for peer broadcasts"""
        while self.running:
            try:
                data, addr = self.socket.recvfrom(4096)
                peer_info = json.loads(data.decode())
                
                peer_id = peer_info.get('neuron_id')
                if peer_id:
                    self.peers.add(peer_id)
                    
                    # Echo back for handshake
                    self.broadcast(peer_info, addr[0])
                    
            except Exception as e:
                pass
    
    def broadcast(self, message: Dict, target_ip: str = None):
        """Broadcast GLOW signal to peers"""
        if target_ip:
            # Unicast to specific peer
            self.socket.sendto(
                json.dumps(message).encode(),
                (target_ip, self.port)
            )
        else:
            # Broadcast to all
            self.socket.sendto(
                json.dumps(message).encode(),
                ('255.255.255.255', self.port)
            )
    
    def discover_peers(self, timeout_sec: int = 5) -> List[str]:
        """Discover neighboring Neuro-Mind instances"""
        discovery_msg = {'type': 'DISCOVER', 'timestamp': time.time()}
        self.broadcast(discovery_msg)
        
        time.sleep(timeout_sec)
        return list(self.peers)


