# ─────────────────────────────────────────────────────────────────────────────

class EEGProvenancePipeline:
    """
    Orchestrates the full pipeline:
      acquire → filter → quantize → hash → LLM → ledger
    """

    def __init__(self,
                 device_type: str = "neuromind_v2",
                 port: Optional[str] = None,
                 api_key: str = DEEPSEEK_API_KEY,
                 ledger_path: Path = LEDGER_PATH):

        self.hw        = HardwareLayer(device_type, port)
        self.proc      = SignalProcessor()
        self.llm       = DeepSeekAnalyser(api_key)
        self.ledger    = ProvenanceLedger(ledger_path)
        self._last_block: Optional[ProvenanceBlock] = None

    # ── Public API ─────────────────────────────────────────────────────────

    def run(self,
            channel: int,
            duration_ms: float,
            bandpass: Optional[Tuple[float, float]] = (1.0, 40.0),
            notch_hz: Optional[float] = 50.0) -> Dict:
        """
        Full pipeline run.
        Returns dict with block info, spectral summary, LLM analysis.
        """
        console.print(f"\n[bold]Pipeline run[/bold]: CH{channel}, {duration_ms}ms")

        # 1. Acquire
        console.print("  [cyan]1/5 Acquiring signal…[/cyan]")
        reading = self.hw.read(channel, duration_ms)
        reading_hash = reading.reading_hash()
        console.print(f"     Reading hash: [dim]{reading_hash[:24]}…[/dim]")

        # 2. Filter
        console.print("  [cyan]2/5 Filtering…[/cyan]")
        if notch_hz:
            reading = self.proc.notch(reading, notch_hz)
        if bandpass:
            reading = self.proc.bandpass(reading, bandpass[0], bandpass[1])

        # 3. Spectral analysis
        console.print("  [cyan]3/5 Spectral analysis…[/cyan]")
        spectral = self.proc.spectral_analysis(reading)

        # 4. Quantize → binary tokens
        console.print("  [cyan]4/5 Quantizing to binary tokens…[/cyan]")
        tokens = BinaryTokens.from_signal(reading.to_numpy(), QUANTIZATION_BITS)
        console.print(f"     Token hash:   [dim]{tokens.token_hash[:24]}…[/dim]")
        console.print(f"     Tokens ({tokens.bit_depth}-bit): {tokens.hex_tokens[:32]}…")

        # 5. LLM analysis
        console.print("  [cyan]5/5 Sending tokens to DeepSeek…[/cyan]")
        prompt   = tokens.to_llm_prompt(reading, spectral)
        analysis = self.llm.analyse(prompt)
        llm_hash = hashlib.sha3_256(analysis.encode()).hexdigest()
        console.print(f"     LLM hash:     [dim]{llm_hash[:24]}…[/dim]")

        # 6. Write to ledger
        block = self.ledger.append(reading, tokens, spectral, analysis)
        self._last_block = block
        console.print(f"\n  [green]✓ Block #{block.block_index} committed[/green]")
        console.print(f"     Block hash:   [dim]{block.block_hash[:32]}…[/dim]")

        return {
            "block_index":    block.block_index,
            "block_hash":     block.block_hash,
            "reading_hash":   reading_hash,
            "token_hash":     tokens.token_hash,
            "llm_hash":       llm_hash,
            "spectral":       spectral,
            "llm_analysis":   analysis,
            "channel":        reading.channel,
            "channel_name":   reading.channel_name,
            "timestamp_utc":  block.timestamp_utc,
            "tokens_preview": tokens.hex_tokens[:64] + "…",
        }

    def verify_ledger(self) -> Dict:
        valid, errors = self.ledger.verify()
        return {
            "valid":       valid,
            "height":      self.ledger.height,
            "head_hash":   self.ledger.head_hash[:32] + "…",
            "errors":      errors,
        }

    def export_block(self, index: int) -> Dict:
        return self.ledger.export_provenance_record(index)

    def check_impedance(self, channel: int) -> Dict:
        return self.hw.get_impedance(channel)


