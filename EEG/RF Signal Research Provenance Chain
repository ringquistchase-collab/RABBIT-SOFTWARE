@dataclass
class EEGReading:
    """Raw EEG acquisition result."""
    device_id: str
    channel: int
    channel_name: str
    sample_rate_hz: float
    duration_ms: float
    timestamp_utc: str
    signal_uv: List[float]           # raw microvolts
    metadata: Dict = field(default_factory=dict)

    def to_numpy(self) -> np.ndarray:
        return np.array(self.signal_uv, dtype=np.float32)

    def reading_hash(self) -> str:
        """Deterministic SHA-3 hash of the raw signal."""
        payload = (
            f"{self.device_id}|{self.channel}|{self.sample_rate_hz}"
            f"|{self.timestamp_utc}|{self.signal_uv}"
        )
        return hashlib.sha3_256(payload.encode()).hexdigest()


@dataclass
class BinaryTokens:
    """EEG signal quantized into a binary/hex token sequence."""
    raw_bytes: bytes           # quantized signal bytes
    hex_tokens: str            # hex string for LLM input
    bit_depth: int             # quantization bits
    n_samples: int
    amplitude_range_uv: Tuple[float, float]
    token_hash: str            # SHA-3 of raw_bytes

    @classmethod
    def from_signal(cls, signal: np.ndarray, bits: int = QUANTIZATION_BITS) -> "BinaryTokens":
        """Quantize float32 signal → unsigned integers → bytes."""
        levels = 2 ** bits
        sig_min, sig_max = float(signal.min()), float(signal.max())
        sig_range = sig_max - sig_min if sig_max != sig_min else 1.0
        # Normalise to [0, levels-1]
        quantized = np.clip(
            ((signal - sig_min) / sig_range * (levels - 1)).astype(np.uint8),
            0, levels - 1
        )
        raw_bytes = quantized.tobytes()
        hex_tokens = quantized.tobytes().hex()
        token_hash = hashlib.sha3_256(raw_bytes).hexdigest()
        return cls(
            raw_bytes=raw_bytes,
            hex_tokens=hex_tokens,
            bit_depth=bits,
            n_samples=len(signal),
            amplitude_range_uv=(round(sig_min, 3), round(sig_max, 3)),
            token_hash=token_hash,
        )

    def to_llm_prompt(self, reading: EEGReading, spectral: Dict) -> str:
        """Build the LLM input prompt from tokens + spectral metadata."""
        # Trim tokens to TOKEN_WINDOW_SIZE samples for context budget
        tokens_for_llm = self.hex_tokens[: TOKEN_WINDOW_SIZE * 2]   # 2 hex chars/byte
        return (
            f"EEG RESEARCH RECORD\n"
            f"Device: {reading.device_id} | Channel: {reading.channel_name} "
            f"(CH{reading.channel}) | Fs={reading.sample_rate_hz}Hz\n"
            f"Duration: {reading.duration_ms}ms | Timestamp: {reading.timestamp_utc}\n"
            f"Amplitude range: {self.amplitude_range_uv[0]:.1f} to "
            f"{self.amplitude_range_uv[1]:.1f} µV\n\n"
            f"SPECTRAL SUMMARY:\n"
            + "\n".join(f"  {b}: {v:.4f} µV²/Hz" for b, v in spectral["bands"].items())
            + f"\n  Peak frequency: {spectral['peak_freq_hz']:.2f} Hz"
            f"\n  SNR: {spectral['snr_db']:.1f} dB\n\n"
            f"BINARY TOKEN SEQUENCE ({self.bit_depth}-bit quantized, "
            f"{TOKEN_WINDOW_SIZE} samples):\n"
            f"{tokens_for_llm}\n\n"
            f"Token hash (SHA-3): {self.token_hash[:16]}…\n"
            f"Analyse this EEG token sequence."
        )


@dataclass
class ProvenanceBlock:
    """One block in the append-only research provenance ledger."""
    block_index: int
    timestamp_utc: str
    previous_hash: str           # links to prior block → chain integrity

    # Hashes of each pipeline stage
    reading_hash: str            # raw signal
    token_hash: str              # quantized binary
    llm_analysis_hash: str       # LLM response

    # Metadata for publication
    device_id: str
    channel: int
    channel_name: str
    sample_rate_hz: float
    duration_ms: float
    spectral_summary: Dict
    llm_analysis: str            # full LLM text (for reference)

    # Block integrity
    block_hash: str = ""         # SHA-3 of all fields above

    def compute_block_hash(self) -> str:
        """Hash all block fields (excluding block_hash itself)."""
        payload = json.dumps({
            "block_index": self.block_index,
            "timestamp_utc": self.timestamp_utc,
            "previous_hash": self.previous_hash,
            "reading_hash": self.reading_hash,
            "token_hash": self.token_hash,
            "llm_analysis_hash": self.llm_analysis_hash,
            "device_id": self.device_id,
            "channel": self.channel,
            "sample_rate_hz": self.sample_rate_hz,
            "duration_ms": self.duration_ms,
        }, sort_keys=True)
        return hashlib.sha3_256(payload.encode()).hexdigest()

    def to_dict(self) -> Dict:
        d = asdict(self)
        d["block_hash"] = self.block_hash
        return d


