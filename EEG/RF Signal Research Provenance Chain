}


class HardwareLayer:
    """
    Thin hardware abstraction — real serial device or physiologically
    realistic simulation with per-channel EEG characteristics.
    """

    def __init__(self, device_type: str = "neuromind_v2",
                 port: Optional[str] = None):
        self.device_type = device_type
        self.spec = DEVICE_SPECS.get(device_type, DEVICE_SPECS["neuromind_v2"])
        self._ser: Optional[Any] = None
        self._connected = False

        if port and HAS_SERIAL:
            try:
                self._ser = serial.Serial(port, baudrate=115200, timeout=1)
                self._connected = True
                console.print(f"[green]✓ Serial: {device_type} on {port}[/green]")
            except Exception as e:
                console.print(f"[yellow]⚠ Serial failed ({e}) — simulation[/yellow]")
        else:
            console.print(f"[blue]ℹ Simulation: {device_type}[/blue]")

    def read(self, channel: int, duration_ms: float) -> EEGReading:
        n = int(self.spec["fs"] * duration_ms / 1000)
        t = np.linspace(0, duration_ms / 1000, n)

        if self._connected and self._ser:
            sig = self._read_hw(channel, n)
        else:
            sig = self._simulate(t, channel)

        ch_name = EEG_10_20[channel] if channel < len(EEG_10_20) else f"CH{channel}"
        return EEGReading(
            device_id=self.device_type,
            channel=channel,
            channel_name=ch_name,
            sample_rate_hz=float(self.spec["fs"]),
            duration_ms=duration_ms,
            timestamp_utc=datetime.datetime.utcnow().isoformat() + "Z",
            signal_uv=sig.tolist(),
            metadata={"simulated": not self._connected},
        )

    def _read_hw(self, ch: int, n: int) -> np.ndarray:
        cmd = struct.pack(">BBH", 0xA5, ch, n)
        self._ser.write(cmd)
        raw = self._ser.read(n * 4)
        if len(raw) >= n * 4:
            return np.frombuffer(raw[: n * 4], dtype=np.float32)
        return np.random.normal(0, 10, n).astype(np.float32)

    def _simulate(self, t: np.ndarray, ch: int) -> np.ndarray:
        """
        Realistic multi-band EEG with per-channel frequency variation.
        Includes occasional eye-blink artefact on frontal channels.
        """
        rng = np.random.default_rng(ch * 31 + int(time.time()) % 997)
        α = 9.0 + rng.uniform(-1.5, 1.5)     # individual alpha peak freq
        θ = 5.5 + rng.uniform(-0.8, 0.8)
        δ = 1.8 + rng.uniform(-0.3, 0.3)
        β = 20.0 + rng.uniform(-3.0, 3.0)

        sig = (
            22.0 * np.sin(2 * np.pi * α * t + rng.uniform(0, 2*np.pi))   # alpha
          + 14.0 * np.sin(2 * np.pi * θ * t + rng.uniform(0, 2*np.pi))   # theta
          + 10.0 * np.sin(2 * np.pi * δ * t + rng.uniform(0, 2*np.pi))   # delta
          +  6.0 * np.sin(2 * np.pi * β * t + rng.uniform(0, 2*np.pi))   # beta
          +  3.0 * rng.standard_normal(len(t))                             # noise
        )

        # Eye-blink artefact on frontal channels
        if ch < 2 and rng.random() < 0.12:
            idx = rng.integers(20, len(t) - 60)
            decay = np.exp(-np.arange(60) / 15.0)
            sig[idx: idx + 60] += 90.0 * decay

        return sig.astype(np.float32)

    def get_impedance(self, ch: int) -> Dict:
        if self._connected and self._ser:
            self._ser.write(struct.pack(">BB", 0xA8, ch))
            raw = self._ser.read(4)
            ohms = struct.unpack(">f", raw)[0] if len(raw) == 4 else 15000.0
        else:
            ohms = float(np.random.uniform(800, 45000))
        quality = "GOOD" if ohms < 5000 else ("FAIR" if ohms < 20000 else "POOR")
        ch_name = EEG_10_20[ch] if ch < len(EEG_10_20) else f"CH{ch}"
        return {"channel": ch, "channel_name": ch_name,
                "impedance_ohms": round(ohms, 1), "quality": quality}


