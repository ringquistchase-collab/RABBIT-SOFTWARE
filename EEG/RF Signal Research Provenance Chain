class SignalProcessor:
    """FFT spectral analysis and clinical filtering."""

    @staticmethod
    def spectral_analysis(reading: EEGReading) -> Dict:
        sig = reading.to_numpy()
        fs  = reading.sample_rate_hz
        n   = len(sig)
        win = np.hanning(n)
        fft_vals = rfft(sig * win)
        freqs    = rfftfreq(n, 1.0 / fs)
        psd      = np.abs(fft_vals) ** 2 / (fs * (win ** 2).sum())

        bands = {}
        for band, (lo, hi) in EEG_BANDS.items():
            mask = (freqs >= lo) & (freqs <= hi)
            bands[band] = float(np.trapezoid(psd[mask], freqs[mask])) if mask.any() else 0.0

        # Peak frequency in 1–50 Hz clinical window
        clin = (freqs >= 1) & (freqs <= 50)
        if clin.any():
            peak_idx  = np.argmax(psd[clin])
            peak_freq = float(freqs[clin][peak_idx])
        else:
            peak_freq = 0.0

        sig_p  = float(np.sum(psd[(freqs >= 0.5) & (freqs <= 40)]))
        noise_p = float(np.mean(psd[-20:])) * len(psd) if len(psd) > 20 else sig_p * 0.1
        snr    = 10 * np.log10(sig_p / (noise_p + 1e-12))

        return {
            "bands": {k: round(v, 5) for k, v in bands.items()},
            "peak_freq_hz": round(peak_freq, 2),
            "snr_db": round(float(snr), 2),
            "dominant_band": max(bands, key=bands.get),
            "theta_alpha_ratio": round(
                bands.get("theta", 0) / (bands.get("alpha", 1e-9) + 1e-9), 3
            ),
        }

    @staticmethod
    def bandpass(reading: EEGReading, lo: float, hi: float, order: int = 4) -> EEGReading:
        sig = reading.to_numpy()
        nyq = reading.sample_rate_hz / 2.0
        lo_n, hi_n = lo / nyq, hi / nyq
        if 0 < lo_n < 1 and 0 < hi_n < 1 and lo_n < hi_n:
            b, a = sp_signal.butter(order, [lo_n, hi_n], btype="band")
            filtered = sp_signal.filtfilt(b, a, sig)
        else:
            filtered = sig.copy()
        reading.signal_uv = filtered.tolist()
        return reading

    @staticmethod
    def notch(reading: EEGReading, freq_hz: float = 50.0, q: float = 30.0) -> EEGReading:
        sig = reading.to_numpy()
        fs  = reading.sample_rate_hz
        if freq_hz < fs / 2:
            b, a = sp_signal.iirnotch(freq_hz, q, fs)
            filtered = sp_signal.filtfilt(b, a, sig)
        else:
            filtered = sig.copy()
        reading.signal_uv = filtered.tolist()
        return reading


