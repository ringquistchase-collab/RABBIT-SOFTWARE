def main():
    parser = argparse.ArgumentParser(
        description="EEG Research Provenance Chain — DeepSeek + local blockchain"
    )
    parser.add_argument("--mode",    choices=["cli", "server"], default="cli")
    parser.add_argument("--device",  default="neuromind_v2",
                        choices=list(DEVICE_SPECS.keys()))
    parser.add_argument("--port",    default=None,
                        help="Serial port e.g. /dev/ttyUSB0")
    parser.add_argument("--ws-port", type=int, default=8765)
    parser.add_argument("--api-key", default=DEEPSEEK_API_KEY)
    parser.add_argument("--ledger",  default="ledger.jsonl",
                        help="Path to ledger file")
    parser.add_argument("--verify",  default=None,
                        help="Verify a ledger file and exit")
    args = parser.parse_args()

    if args.verify:
        verify_standalone(args.verify)
        return

    pipeline = EEGProvenancePipeline(
        device_type  = args.device,
        port         = args.port,
        api_key      = args.api_key,
        ledger_path  = Path(args.ledger),
    )

    if args.mode == "cli":
        run_cli(pipeline)
    else:
        # WebSocket server mode (async)
        async def ws_server():
            try:
                import websockets
            except ImportError:
                print("pip install websockets")
                return

            async def handler(ws):
                async for msg in ws:
                    try:
                        pkt = json.loads(msg)
                        cmd = pkt.get("cmd", "")
                        if cmd == "record":
                            result = pipeline.run(
                                pkt.get("channel", 0),
                                pkt.get("duration_ms", 2000),
                            )
                            await ws.send(json.dumps(result))
                        elif cmd == "verify":
                            await ws.send(json.dumps(pipeline.verify_ledger()))
                        elif cmd == "export":
                            await ws.send(json.dumps(
                                pipeline.export_block(pkt.get("index", 0))
                            ))
                        else:
                            await ws.send(json.dumps({"error": f"unknown cmd: {cmd}"}))
                    except Exception as e:
                        await ws.send(json.dumps({"error": str(e)}))

            print(f"WS server on ws://0.0.0.0:{args.ws_port}")
            async with websockets.serve(handler, "0.0.0.0", args.ws_port):
                await asyncio.Future()

        asyncio.run(ws_server())


if __name__ == "__main__":
    main()
