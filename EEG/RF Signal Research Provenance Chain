def run_cli(pipeline: EEGProvenancePipeline):
    console.rule("[bold cyan]EEG Research Provenance Chain[/bold cyan]")
    console.print(f"Ledger: [dim]{LEDGER_PATH.resolve()}[/dim]")
    console.print(f"Chain height: {pipeline.ledger.height} blocks\n")

    EXAMPLES = [
        "record ch0 2000",
        "record ch1 1000",
        "verify",
        "export 0",
        "impedance 0",
        "status",
    ]
    console.print("[bold]Commands:[/bold]")
    console.print("  record <ch> <ms>   — acquire, tokenize, hash, analyse, commit")
    console.print("  verify             — verify full ledger chain integrity")
    console.print("  export <index>     — export provenance record for publication")
    console.print("  impedance <ch>     — check electrode impedance")
    console.print("  status             — device + ledger status")
    console.print("  quit\n")

    while True:
        try:
            raw = input(">>> ").strip()
        except (EOFError, KeyboardInterrupt):
            console.print("\n[yellow]Goodbye.[/yellow]")
            break

        if not raw:
            continue
        parts = raw.lower().split()
        cmd   = parts[0]

        if cmd in ("quit", "exit", "q"):
            break

        elif cmd == "record":
            ch  = int(parts[1]) if len(parts) > 1 else 0
            ms  = float(parts[2]) if len(parts) > 2 else 2000.0
            result = pipeline.run(ch, ms)
            console.print(f"\n[bold green]Block #{result['block_index']}[/bold green]")
            console.print(f"  Channel  : {result['channel_name']} (CH{result['channel']})")
            console.print(f"  Dominant : {result['spectral']['dominant_band']} "
                          f"@ {result['spectral']['peak_freq_hz']} Hz")
            console.print(f"  SNR      : {result['spectral']['snr_db']} dB")
            console.print(f"  Tokens   : {result['tokens_preview']}")
            console.print(f"\n[bold]LLM Analysis:[/bold]")
            for line in result['llm_analysis'].split("\n"):
                console.print(f"  {line}")

        elif cmd == "verify":
            result = pipeline.verify_ledger()
            if result["valid"]:
                console.print(f"[green]✓ Chain VALID — {result['height']} blocks[/green]")
            else:
                console.print(f"[red]✗ Chain INVALID — {len(result['errors'])} error(s)[/red]")
                for e in result["errors"]:
                    console.print(f"  [red]{e}[/red]")

        elif cmd == "export":
            idx = int(parts[1]) if len(parts) > 1 else 0
            rec = pipeline.export_block(idx)
            console.print(json.dumps(rec, indent=2))

        elif cmd == "impedance":
            ch = int(parts[1]) if len(parts) > 1 else 0
            r  = pipeline.check_impedance(ch)
            quality_color = {"GOOD": "green", "FAIR": "yellow", "POOR": "red"}.get(r["quality"], "white")
            console.print(f"  [{quality_color}]{r['channel_name']}: "
                          f"{r['impedance_ohms']} Ω — {r['quality']}[/{quality_color}]")

        elif cmd == "status":
            console.print(f"  Device      : {pipeline.hw.device_type}")
            console.print(f"  Connected   : {pipeline.hw._connected}")
            console.print(f"  Sample rate : {pipeline.hw.spec['fs']} Hz")
            console.print(f"  Channels    : {pipeline.hw.spec['channels']}")
            console.print(f"  Ledger      : {LEDGER_PATH.resolve()}")
            console.print(f"  Chain height: {pipeline.ledger.height}")
            v, _ = pipeline.ledger.verify()
            console.print(f"  Chain valid : {'✓' if v else '✗'}")

        else:
            console.print(f"[yellow]Unknown command: {cmd}[/yellow]")

    console.rule()


