# PROVENANCE LEDGER  (local append-only blockchain)
# ─────────────────────────────────────────────────────────────────────────────

class ProvenanceLedger:
    """
    Append-only JSONL ledger where each line is a block.
    Each block SHA-3 hashes:
      • raw EEG reading
      • binary token sequence
      • LLM analysis text
      • all fields of the previous block  ← makes tampering detectable
    """

    def __init__(self, path: Path = LEDGER_PATH):
        self.path = path
        self._lock = threading.Lock()
        self._blocks: List[Dict] = []

        if path.exists():
            self._load()
            console.print(f"[cyan]📒 Ledger loaded: {len(self._blocks)} blocks[/cyan]")
        else:
            console.print(f"[cyan]📒 New ledger: {path}[/cyan]")

    def _load(self):
        with open(self.path, "r") as f:
            for line in f:
                line = line.strip()
                if line:
                    self._blocks.append(json.loads(line))

    @property
    def head_hash(self) -> str:
        return self._blocks[-1]["block_hash"] if self._blocks else GENESIS_HASH

    @property
    def height(self) -> int:
        return len(self._blocks)

    def append(self, reading: EEGReading, tokens: BinaryTokens,
               spectral: Dict, llm_analysis: str) -> ProvenanceBlock:
        """Create and persist a new block."""
        with self._lock:
            llm_hash = hashlib.sha3_256(llm_analysis.encode()).hexdigest()
            block = ProvenanceBlock(
                block_index=self.height,
                timestamp_utc=datetime.datetime.utcnow().isoformat() + "Z",
                previous_hash=self.head_hash,
                reading_hash=reading.reading_hash(),
                token_hash=tokens.token_hash,
                llm_analysis_hash=llm_hash,
                device_id=reading.device_id,
                channel=reading.channel,
                channel_name=reading.channel_name,
                sample_rate_hz=reading.sample_rate_hz,
                duration_ms=reading.duration_ms,
                spectral_summary=spectral,
                llm_analysis=llm_analysis,
            )
            block.block_hash = block.compute_block_hash()

            # Append to file
            with open(self.path, "a") as f:
                f.write(json.dumps(block.to_dict()) + "\n")

            self._blocks.append(block.to_dict())
            return block

    def verify(self) -> Tuple[bool, List[str]]:
        """
        Verify full chain integrity.
        Returns (valid: bool, list of errors).
        """
        errors = []
        prev_hash = GENESIS_HASH

        for i, raw in enumerate(self._blocks):
            # Re-derive block_hash from fields
            b = ProvenanceBlock(**{k: v for k, v in raw.items() if k != "block_hash"})
            expected_hash = b.compute_block_hash()

            if raw["block_hash"] != expected_hash:
                errors.append(f"Block {i}: block_hash mismatch (tampered?)")

            if raw["previous_hash"] != prev_hash:
                errors.append(f"Block {i}: chain break — previous_hash mismatch")

            prev_hash = raw["block_hash"]

        return len(errors) == 0, errors

    def get_block(self, index: int) -> Optional[Dict]:
        if 0 <= index < len(self._blocks):
            return self._blocks[index]
        return None

    def export_provenance_record(self, block_index: int) -> Dict:
        """
        Export a self-contained provenance record suitable for
        supplementary material in a research publication.
        """
        block = self.get_block(block_index)
        if not block:
            return {"error": "Block not found"}

        valid, errs = self.verify()
        return {
            "provenance_record": {
                "ledger_file": str(self.path),
                "chain_height": self.height,
                "chain_valid": valid,
                "chain_errors": errs,
                "block": block,
                "verification_note": (
                    "Chain integrity verified: each block_hash is SHA-3(block fields). "
                    "The previous_hash field links each block to its predecessor, "
                    "making retroactive modification detectable."
                    if valid else
                    "WARNING: Chain integrity check FAILED. See chain_errors."
                ),
            }
        }


