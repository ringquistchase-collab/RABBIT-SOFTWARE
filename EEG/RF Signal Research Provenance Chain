class DeepSeekAnalyser:
    """Send token prompt to DeepSeek; return structured analysis."""

    def __init__(self, api_key: str = DEEPSEEK_API_KEY):
        self.client = None
        if HAS_OPENAI and api_key and api_key != "YOUR_DEEPSEEK_API_KEY":
            self.client = OpenAI(api_key=api_key, base_url=DEEPSEEK_BASE_URL)
            console.print("[green]✓ DeepSeek API ready[/green]")
        else:
            console.print("[yellow]⚠ DeepSeek not configured — local fallback active[/yellow]")

    def analyse(self, prompt: str) -> str:
        """Send token prompt, return analysis string."""
        if self.client:
            try:
                resp = self.client.chat.completions.create(
                    model=DEEPSEEK_MODEL,
                    messages=[
                        {"role": "system", "content": SYSTEM_PROMPT},
                        {"role": "user",   "content": prompt},
                    ],
                    temperature=0.3,
                    max_tokens=512,
                )
                return resp.choices[0].message.content.strip()
            except Exception as e:
                return f"[API ERROR] {e}"
        else:
            return self._local_fallback(prompt)

    @staticmethod
    def _local_fallback(prompt: str) -> str:
        """Rule-based fallback when no API key is set."""
        # Parse spectral info from prompt for realistic output
        lines = prompt.split("\n")
        dominant = "alpha"
        peak = "10.00"
        snr  = "12.0"
        for line in lines:
            if "dominant_band" in line.lower():
                dominant = line.split(":")[-1].strip()
            if "Peak frequency" in line:
                peak = line.split(":")[-1].strip().split()[0]
            if "SNR" in line:
                snr = line.split(":")[-1].strip().split()[0]

        return (
            f"SIGNAL_QUALITY: GOOD — SNR {snr} dB, no saturation detected\n"
            f"DOMINANT_RHYTHM: {dominant} at {peak} Hz\n"
            f"FEATURES: posterior dominant rhythm, normal background activity, "
            f"no interictal discharges\n"
            f"INTERPRETATION: Token sequence shows typical resting-state EEG with "
            f"posterior alpha dominance. Theta/alpha ratio within normal range. "
            f"Signal quality adequate for research purposes.\n"
            f"FLAGS: NONE\n"
            f"[NOTE: Generated by local fallback — set DEEPSEEK_API_KEY for real LLM analysis]"
        )


