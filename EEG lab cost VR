def aes_encrypt(plaintext: bytes, key: bytes) -> Tuple[bytes, bytes, bytes]:
    """AES‑256‑GCM encryption. Returns (ciphertext, nonce, tag)."""
    nonce = os.urandom(12)
    cipher = AESGCM(key)
    ciphertext = cipher.encrypt(nonce, plaintext, None)
    tag = ciphertext[-16:]
    return ciphertext[:-16], nonce, tag

