class PersonalWellBeingRecorder:
    """
    Records chemical/hormonal changes for Chase's well-being only
    NO external data sharing - strictly personal optimization
    """
   
    def __init__(self, blockchain: NodeTunedBlockchain):
        self.blockchain = blockchain
        self.well_being_db = sqlite3.connect("chase_well_being.db", check_same_thread=False)
        self._init_database()
       
        # Only track well-being improving chemicals
        self.tracked_chemicals = ['dopamine', 'serotonin', 'oxytocin', 'endorphins', 'GABA']
        self.blocked_chemicals = ['sex_hormones_external', 'recreational_drugs', 'anger_markers']
       
