class Block:
    """Single block in the personal blockchain"""
   
    def __init__(self, index: int, previous_hash: str, transactions: List, timestamp: float):
        self.index = index
        self.previous_hash = previous_hash
        self.transactions = transactions
        self.timestamp = timestamp
        self.nonce = 0
        self.hash = self.calculate_hash()
   
    def calculate_hash(self) -> str:
        """Calculate block hash using SHA-3"""
        block_string = f"{self.index}{self.previous_hash}{self.transactions}{self.timestamp}{self.nonce}"
        return hashlib.sha3_256(block_string.encode()).hexdigest()
   
    def mine(self, difficulty: int = 4):
        """Proof of RF (simulated - uses emotional intensity as difficulty)"""
        target = '0' * difficulty
        while self.hash[:difficulty] != target:
            self.nonce += 1
            self.hash = self.calculate_hash()


