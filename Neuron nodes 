        print(f"   Purpose: Chase's optimization only")
        print(f"   Tracked Chemicals: {self.tracked_chemicals}")
        print(f"   Principle: NO external sharing")
   
    def _init_database(self):
        """Initialize local well-being database (never shared)"""
        cursor = self.well_being_db.cursor()
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS well_being_records (
                record_id TEXT PRIMARY KEY,
                timestamp REAL,
                well_being_score REAL,
                emotion TEXT,
                dopamine REAL,
                serotonin REAL,
                oxytocin REAL,
                endorphins REAL,
                gaba REAL,
                notes TEXT
            )
        ''')
       
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS daily_reflections (
                reflection_id TEXT PRIMARY KEY,
                date TEXT,
                well_being_score REAL,
                insights TEXT,
                actions_taken TEXT
            )
        ''')
        self.well_being_db.commit()
   
    def record_chemical_change(self, chemical: str, change: float, context: str) -> Dict:
        """Record chemical change for well-being tracking"""
        if chemical in self.blocked_chemicals:
            return {'status': 'BLOCKED', 'reason': f'{chemical} not tracked for well-being'}
       
        if chemical not in self.tracked_chemicals:
            self.tracked_chemicals.append(chemical)
       
        # Create transaction for blockchain
        transaction = {
            'type': 'chemical_record',
            'chemical': chemical,
            'change': change,
            'context': context,
            'chemical_changes': {chemical: change},
            'timestamp': time.time()
        }
       
        result = self.blockchain.add_transaction(transaction)
       
        # Store in local database
        cursor = self.well_being_db.cursor()
        cursor.execute('''
            INSERT INTO well_being_records (record_id, timestamp, well_being_score, emotion,
                                           dopamine, serotonin, oxytocin, endorphins, gaba, notes)
            VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
        ''', (
            hashlib.md5(f"{time.time()}_{chemical}".encode()).hexdigest()[:16],
            time.time(),
            self.blockchain.moral_guide.calculate_well_being(),
            self.blockchain.moral_guide.current_emotion.value,
            None if chemical != 'dopamine' else change,
            None if chemical != 'serotonin' else change,
            None if chemical != 'oxytocin' else change,
            None if chemical != 'endorphins' else change,
            None if chemical != 'GABA' else change,
            context
        ))
        self.well_being_db.commit()
       
        return {
            'status': result['status'],
            'chemical': chemical,
            'change': change,
            'well_being_impact': self._calculate_impact(chemical, change)
        }
   
    def _calculate_impact(self, chemical: str, change: float) -> float:
        """Calculate impact on well-being"""
        positive_impact = {
            'dopamine': 0.3,
            'serotonin': 0.35,
            'oxytocin': 0.4,
            'endorphins': 0.25,
            'GABA': 0.2
        }
        return positive_impact.get(chemical, 0.1) * max(0, change)
   
    def record_daily_reflection(self, insights: str, actions: str) -> Dict:
        """Record daily reflection for well-being improvement"""
        cursor = self.well_being_db.cursor()
        reflection_id = hashlib.md5(f"{datetime.now().date()}_{insights}".encode()).hexdigest()[:16]
       
        cursor.execute('''
            INSERT INTO daily_reflections (reflection_id, date, well_being_score, insights, actions_taken)
            VALUES (?, ?, ?, ?, ?)
        ''', (
            reflection_id,
            datetime.now().isoformat(),
            self.blockchain.moral_guide.calculate_well_being(),
            insights,
            actions
        ))
        self.well_being_db.commit()
       
        # Create blockchain transaction
        transaction = {
            'type': 'daily_reflection',
            'insights_hash': hashlib.sha256(insights.encode()).hexdigest()[:16],
            'well_being_at_time': self.blockchain.moral_guide.calculate_well_being(),
            'timestamp': time.time()
        }
        self.blockchain.add_transaction(transaction)
       
        return {
            'reflection_id': reflection_id,
            'date': datetime.now().isoformat(),
            'well_being_score': self.blockchain.moral_guide.calculate_well_being(),
            'status': 'recorded'
        }
   
    def get_well_being_report(self, days: int = 7) -> Dict:
        """Get well-being report (for Chase only)"""
        cursor = self.well_being_db.cursor()
        cutoff = time.time() - (days * 86400)
       
        cursor.execute('''
            SELECT well_being_score, emotion, timestamp FROM well_being_records
            WHERE timestamp > ? ORDER BY timestamp
        ''', (cutoff,))
       
        records = cursor.fetchall()
       
        if not records:
            return {'error': 'No records found'}
       
        scores = [r[0] for r in records]
       
        return {
            'period_days': days,
            'average_well_being': np.mean(scores),
            'trend': 'improving' if scores[-1] > scores[0] else 'declining' if scores[-1] < scores[0] else 'stable',
            'best_day': max(records, key=lambda x: x[0])[2] if records else None,
            'principle': 'FOR_CHASE_EYES_ONLY'
        }


