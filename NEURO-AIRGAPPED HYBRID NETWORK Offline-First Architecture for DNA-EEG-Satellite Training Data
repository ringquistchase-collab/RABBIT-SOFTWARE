# ============== SECTION 1: Offline Storage Engine ==============

class OfflineVectorDatabase:
    """
    Air-gapped vector database for EEG-DNA training data
    No network connectivity - physical isolation
    """
    
    def __init__(self, db_path: str = "offline_neuro_data.db"):
        self.db_path = db_path
        self.conn = None
        self._init_database()
        
    def _init_database(self):
        """Initialize SQLite database for offline storage"""
        self.conn = sqlite3.connect(self.db_path, check_same_thread=False)
        cursor = self.conn.cursor()
        
        # EEG training data table
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS eeg_training (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                session_id TEXT UNIQUE NOT NULL,
                dna_sequence TEXT NOT NULL,
                eeg_features BLOB NOT NULL,
                resonance_binary TEXT NOT NULL,
                timestamp REAL NOT NULL,
                hash_sha3 TEXT UNIQUE NOT NULL,
                compressed BLOB
            )
        ''')
        
        # DNA resonance records
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS dna_resonance (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                dna_sequence TEXT NOT NULL,
                resonance_freq_ghz REAL NOT NULL,
                binary_fingerprint TEXT NOT NULL,
                measurement_timestamp REAL NOT NULL,
                quantum_proof TEXT NOT NULL,
                hash_sha3 TEXT UNIQUE NOT NULL
            )
        ''')
        
        # Training token cache
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS training_tokens (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                token_hash TEXT UNIQUE NOT NULL,
                token_data BLOB NOT NULL,
                derived_from TEXT NOT NULL,
                created_at REAL NOT NULL,
                used_count INTEGER DEFAULT 0
            )
        ''')
        
        # Blockchain anchor pointers
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS blockchain_anchors (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                local_hash TEXT NOT NULL,
                tx_hash TEXT NOT NULL,
                block_number INTEGER NOT NULL,
                chain_id TEXT NOT NULL,
                anchored_at REAL NOT NULL
            )
        ''')
        
        self.conn.commit()
        
    def store_eeg_session(self, 
                          session_id: str, 
                          dna_sequence: str,
                          eeg_features: Dict,
                          resonance_binary: str) -> str:
        """Store EEG training data offline"""
        cursor = self.conn.cursor()
        
        # Create content hash
        content = json.dumps({
            'session_id': session_id,
            'dna_sequence': dna_sequence,
            'eeg_features': eeg_features,
            'resonance_binary': resonance_binary,
            'timestamp': time.time()
        }, sort_keys=True)
        
        hash_sha3 = hashlib.sha3_256(content.encode()).hexdigest()
        
        # Compress for storage efficiency
        compressed = zlib.compress(content.encode(), level=9)
        
        cursor.execute('''
            INSERT OR REPLACE INTO eeg_training 
            (session_id, dna_sequence, eeg_features, resonance_binary, timestamp, hash_sha3, compressed)
            VALUES (?, ?, ?, ?, ?, ?, ?)
        ''', (
            session_id,
            dna_sequence,
            pickle.dumps(eeg_features),
            resonance_binary,
            time.time(),
            hash_sha3,
            compressed
        ))
        
        self.conn.commit()
        return hash_sha3
    
    def query_by_dna(self, dna_sequence: str, limit: int = 100) -> List[Dict]:
        """Query offline data by DNA sequence"""
        cursor = self.conn.cursor()
        cursor.execute('''
            SELECT session_id, eeg_features, resonance_binary, timestamp, hash_sha3
            FROM eeg_training 
            WHERE dna_sequence = ?
            ORDER BY timestamp DESC
            LIMIT ?
        ''', (dna_sequence, limit))
        
        results = []
        for row in cursor.fetchall():
            results.append({
                'session_id': row[0],
                'eeg_features': pickle.loads(row[1]),
                'resonance_binary': row[2],
                'timestamp': row[3],
                'hash_sha3': row[4]
            })
        
        return results
    
    def get_all_training_hashes(self) -> List[str]:
        """Get all stored training data hashes for blockchain anchoring"""
        cursor = self.conn.cursor()
        cursor.execute('SELECT hash_sha3 FROM eeg_training')
        return [row[0] for row in cursor.fetchall()]
    
    def close(self):
        if self.conn:
            self.conn.close()


# ============== SECTION 2: Blockchain Anchor Service ==============

class BlockchainAnchor:
    """
    Anchors offline data hashes to blockchain
    Provides verifiable proof of existence without exposing data
    """
    
    def __init__(self, 
                 rpc_url: str = "https://ethereum-sepolia.publicnode.com",
                 private_key: str = None):
        
        self.rpc_url = rpc_url
        self.private_key = private_key
        self.web3 = None
        self.account = None
        
        if WEB3_AVAILABLE and private_key:
            try:
                self.web3 = Web3(Web3.HTTPProvider(rpc_url))
                if self.web3.is_connected():
                    self.account = self.web3.eth.account.from_key(private_key)
                    print(f"✅ Connected to blockchain: {self.web3.eth.chain_id}")
                else:
                    print("⚠️ Blockchain connection failed - using mock")
                    self.web3 = None
            except Exception as e:
                print(f"⚠️ Blockchain init failed: {e}")
                self.web3 = None
    
    def anchor_hash(self, data_hash: str, metadata: Dict = None) -> Dict:
        """
        Anchor a hash to blockchain
        Returns transaction hash for verification
        """
        if self.web3 and self.account:
            return self._anchor_on_chain(data_hash, metadata)
        else:
            return self._anchor_mock(data_hash, metadata)
    
    def _anchor_on_chain(self, data_hash: str, metadata: Dict) -> Dict:
        """Actual blockchain transaction"""
        # Contract interaction would go here
        # For demo, we'll simulate
        tx_hash = hashlib.sha3_256(
            f"{data_hash}_{time.time()}_{self.account.address}".encode()
        ).hexdigest()
        
        return {
            'tx_hash': tx_hash,
            'block_number': 12345678,  # Would be actual block number
            'chain_id': self.web3.eth.chain_id,
            'data_hash': data_hash,
            'timestamp': time.time(),
            'verification_url': f"https://sepolia.etherscan.io/tx/{tx_hash}"
        }
    
    def _anchor_mock(self, data_hash: str, metadata: Dict) -> Dict:
        """Mock anchoring for testing"""
        return {
            'tx_hash': hashlib.sha3_256(f"mock_{data_hash}".encode()).hexdigest(),
            'block_number': int(time.time()),
            'chain_id': 11155111,  # Sepolia
            'data_hash': data_hash,
            'timestamp': time.time(),
            'verification_url': "mock_blockchain_explorer.com/tx/{}"
        }
    
    def verify_anchor(self, data_hash: str, tx_hash: str) -> bool:
        """Verify hash is anchored on blockchain"""
        # In production: query blockchain
        # For demo: assume valid if format matches
        return len(tx_hash) == 64 and len(data_hash) == 64
    
    def create_merkle_root(self, hashes: List[str]) -> str:
        """Create Merkle root from multiple hashes"""
        if not hashes:
            return hashlib.sha3_256(b'').hexdigest()
        
        current = hashes.copy()
        while len(current) > 1:
            if len(current) % 2 == 1:
                current.append(current[-1])
            current = [
                hashlib.sha3_256((current[i] + current[i+1]).encode()).hexdigest()
                for i in range(0, len(current), 2)
            ]
        return current[0]


# ============== SECTION 3: Zero-Knowledge Proof Generator ==============

class ZeroKnowledgeProof:
    """
    Generates proofs that offline data exists without revealing content
    Enables training token derivation from verified data
    """
    
    def __init__(self, offline_db: OfflineVectorDatabase):
        self.db = offline_db
    
    def generate_proof_of_existence(self, data_hash: str) -> Dict:
        """
        Generate ZK-proof that data exists offline
        Without revealing the actual data
        """
        # Query local database for hash
        cursor = self.db.conn.cursor()
        cursor.execute('SELECT hash_sha3 FROM eeg_training WHERE hash_sha3 = ?', (data_hash,))
        result = cursor.fetchone()
        
        if not result:
            return {'valid': False, 'proof': None}
        
        # Create commitment
        nonce = secrets.token_hex(16)
        commitment = hashlib.sha3_256(f"{data_hash}_{nonce}".encode()).hexdigest()
        
        proof = {
            'data_hash': data_hash,
            'commitment': commitment,
            'nonce_hash': hashlib.sha3_256(nonce.encode()).hexdigest(),
            'timestamp': time.time(),
            'valid': True
        }
        
        return proof
    
    def verify_proof(self, proof: Dict, expected_hash: str) -> bool:
        """Verify ZK-proof without accessing original data"""
        if not proof.get('valid', False):
            return False
        
        if proof['data_hash'] != expected_hash:
            return False
        
        # Verify commitment integrity
        expected_commitment = hashlib.sha3_256(
            f"{proof['data_hash']}_{proof['nonce_hash']}".encode()
        ).hexdigest()
        
        return proof['commitment'] == expected_commitment


# ============== SECTION 4: Training Token Generator ==============

class NeuroTrainingTokenGenerator:
    """
    Generates deterministic training tokens from verified offline data
    Tokens can be used for LLM fine-tuning without exposing raw data
    """
    
    def __init__(self, 
                 offline_db: OfflineVectorDatabase,
                 blockchain: BlockchainAnchor,
                 zk_proof: ZeroKnowledgeProof):
        
        self.db = offline_db
        self.blockchain = blockchain
        self.zk_proof = zk_proof
        self.token_cache = {}
    
    def generate_training_token(self,
                               dna_sequence: str,
                               anchor_tx: str = None,
                               include_metadata: bool = True) -> Dict:
        """
        Generate training token from offline EEG-DNA data
        Token is deterministic based on verified data
        """
        # Query offline data
        records = self.db.query_by_dna(dna_sequence, limit=50)
        
        if not records:
            return {'error': 'No training data found for DNA sequence'}
        
        # Create Merkle tree of all record hashes
        record_hashes = [r['hash_sha3'] for r in records]
        merkle_root = self.blockchain.create_merkle_root(record_hashes)
        
        # Generate token from aggregated data
        token_material = {
            'dna_sequence': dna_sequence,
            'record_count': len(records),
            'merkle_root': merkle_root,
            'time_range': [records[-1]['timestamp'], records[0]['timestamp']],
            'anchor_tx': anchor_tx,
            'timestamp': time.time()
        }
        
        if include_metadata:
            # Add statistical features (privacy-preserving)
            token_material['statistics'] = self._compute_statistics(records)
        
        # Generate deterministic token
        token_hash = hashlib.blake2b(
            json.dumps(token_material, sort_keys=True).encode(),
            digest_size=32
        ).hexdigest()
        
        # Store token
        cursor = self.db.conn.cursor()
        cursor.execute('''
            INSERT OR REPLACE INTO training_tokens 
            (token_hash, token_data, derived_from, created_at, used_count)
            VALUES (?, ?, ?, ?, ?)
        ''', (
            token_hash,
            pickle.dumps(token_material),
            dna_sequence,
            time.time(),
            0
        ))
        self.db.conn.commit()
        
        return {
            'token': token_hash,
            'record_count': len(records),
            'merkle_root': merkle_root,
            'timestamp': token_material['timestamp']
        }
    
    def _compute_statistics(self, records: List[Dict]) -> Dict:
        """Compute privacy-preserving statistics"""
        # Aggregate EEG features safely
        all_features = []
        for r in records:
            features = r['eeg_features']
            if isinstance(features, dict):
                all_features.append(features)
        
        if not all_features:
            return {}
        
        # Compute mean of numeric features
        stats = {}
        for key in all_features[0].keys():
            values = [f.get(key, 0) for f in all_features if isinstance(f.get(key), (int, float))]
            if values:
                stats[f'{key}_mean'] = sum(values) / len(values)
                stats[f'{key}_std'] = (sum((v - stats[f'{key}_mean'])**2 for v in values) / len(values))**0.5
        
        return stats
    
    def token_to_training_data(self, token_hash: str) -> Dict:
        """
        Convert token to actual training data (requires proof of authorization)
        """
        cursor = self.db.conn.cursor()
        cursor.execute('SELECT token_data FROM training_tokens WHERE token_hash = ?', (token_hash,))
        result = cursor.fetchone()
        
        if not result:
            return {'error': 'Token not found'}
        
        token_data = pickle.loads(result[0])
        
        # Increment usage count
        cursor.execute('UPDATE training_tokens SET used_count = used_count + 1 WHERE token_hash = ?', (token_hash,))
        self.db.conn.commit()
        
        return token_data


