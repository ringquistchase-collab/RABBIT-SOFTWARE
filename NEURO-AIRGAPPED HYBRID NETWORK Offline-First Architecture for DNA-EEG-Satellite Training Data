# ============== SECTION 6: Complete Neuro Training Network ==============

class NeuroTrainingNetwork:
    """
    Complete offline-first training network for DNA-EEG-satellite data
    Integrates offline storage + blockchain anchoring + P2P discovery
    """
    
    def __init__(self, 
                 node_name: str,
                 blockchain_rpc: str = None,
                 blockchain_private_key: str = None):
        
        self.node_name = node_name
        self.node_id = hashlib.sha3_256(node_name.encode()).hexdigest()[:16]
        
        # Offline storage
        self.offline_db = OfflineVectorDatabase(f"neuro_data_{self.node_id}.db")
        
        # Blockchain anchor
        self.blockchain = BlockchainAnchor(blockchain_rpc, blockchain_private_key)
        
        # ZK proof system
        self.zk_proof = ZeroKnowledgeProof(self.offline_db)
        
        # Token generator
        self.token_gen = NeuroTrainingTokenGenerator(self.offline_db, self.blockchain, self.zk_proof)
        
        # P2P network
        self.p2p = NeuroP2PNetwork(self.node_id)
        
        # Training data cache
        self.training_cache = {}
        
        print(f"🧠 Neuro Training Network: {node_name}")
        print(f"   Node ID: {self.node_id}")
        print(f"   Offline DB: {self.offline_db.db_path}")
    
    def start(self):
        """Start all network services"""
        self.p2p.start()
        print("✅ Network services started")
    
    def ingest_eeg_data(self,
                       session_id: str,
                       dna_sequence: str,
                       eeg_features: Dict,
                       resonance_binary: str) -> Dict:
        """
        Ingest EEG training data - stored offline
        Returns hash for blockchain anchoring
        """
        # Store offline
        data_hash = self.offline_db.store_eeg_session(
            session_id, dna_sequence, eeg_features, resonance_binary
        )
        
        # Anchor hash to blockchain
        anchor = self.blockchain.anchor_hash(data_hash, {
            'node': self.node_id,
            'dna': dna_sequence[:8],
            'session': session_id
        })
        
        # Store anchor reference
        cursor = self.offline_db.conn.cursor()
        cursor.execute('''
            INSERT INTO blockchain_anchors (local_hash, tx_hash, block_number, chain_id, anchored_at)
            VALUES (?, ?, ?, ?, ?)
        ''', (data_hash, anchor['tx_hash'], anchor['block_number'], anchor['chain_id'], anchor['timestamp']))
        self.offline_db.conn.commit()
        
        print(f"📥 Ingested: {session_id} → {data_hash[:16]}...")
        print(f"   Anchored: {anchor['tx_hash'][:16]}...")
        
        return {
            'data_hash': data_hash,
            'tx_hash': anchor['tx_hash'],
            'block_number': anchor['block_number'],
            'verification_url': anchor['verification_url']
        }
    
    def generate_training_token(self, dna_sequence: str) -> Dict:
        """
        Generate training token from verified offline data
        Token can be shared for collaborative training
        """
        # Generate token
        token = self.token_gen.generate_training_token(dna_sequence)
        
        if 'error' in token:
            return token
        
        # Create proof of existence
        proof = self.zk_proof.generate_proof_of_existence(token['merkle_root'])
        
        # Broadcast to network
        self.p2p.broadcast_proof(proof, f"token_{dna_sequence}")
        
        return {
            'token': token['token'],
            'record_count': token['record_count'],
            'proof': proof,
            'node': self.node_id
        }
    
    def fetch_remote_training_data(self, dna_sequence: str, peer_id: str = None) -> List[Dict]:
        """
        Fetch training data from remote peers
        Uses blockchain verification
        """
        # Request token from peer
        response = self.p2p.request_training_token(dna_sequence, peer_id)
        
        if not response or 'token' not in response:
            return []
        
        # Verify token on blockchain
        token_hash = response['token']
        
        # In production: query blockchain for anchor
        # For demo: assume valid
        
        # Decode token to training data
        training_data = self.token_gen.token_to_training_data(token_hash)
        
        if 'error' in training_data:
            return []
        
        return [training_data]
    
    def create_training_batch(self, dna_sequence: str, min_records: int = 10) -> Dict:
        """
        Create training batch from local + remote data
        """
        # Local data
        local_records = self.offline_db.query_by_dna(dna_sequence, limit=min_records)
        
        # Generate token for sharing
        token = self.generate_training_token(dna_sequence)
        
        # Create batch
        batch = {
            'dna_sequence': dna_sequence,
            'local_records': len(local_records),
            'token': token.get('token'),
            'merkle_root': token.get('merkle_root'),
            'timestamp': time.time(),
            'node': self.node_id
        }
        
        # Compute batch hash
        batch['batch_hash'] = hashlib.sha3_256(
            json.dumps(batch, sort_keys=True).encode()
        ).hexdigest()
        
        # Store batch reference
        batch_cache_key = f"{dna_sequence}_{int(time.time())}"
        self.training_cache[batch_cache_key] = batch
        
        return batch
    
    def get_training_status(self) -> Dict:
        """Get current training data status"""
        cursor = self.offline_db.conn.cursor()
        
        # Count records by DNA
        cursor.execute('SELECT dna_sequence, COUNT(*) FROM eeg_training GROUP BY dna_sequence')
        dna_counts = dict(cursor.fetchall())
        
        # Count blockchain anchors
        cursor.execute('SELECT COUNT(*) FROM blockchain_anchors')
        anchor_count = cursor.fetchone()[0]
        
        # Count tokens
        cursor.execute('SELECT COUNT(*) FROM training_tokens')
        token_count = cursor.fetchone()[0]
        
        return {
            'node': self.node_name,
            'node_id': self.node_id,
            'dna_sequences': len(dna_counts),
            'total_records': sum(dna_counts.values()),
            'records_by_dna': dna_counts,
            'blockchain_anchors': anchor_count,
            'training_tokens': token_count,
            'peers': list(self.p2p.peers)
        }


