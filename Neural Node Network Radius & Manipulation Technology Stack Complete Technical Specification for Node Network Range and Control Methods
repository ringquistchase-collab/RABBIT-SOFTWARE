class AntennaSpecification:
    """Antenna types for range extension"""
    
    ANTENNA_TYPES = {
        'dipole': {
            'gain_dbi': 2.15,
            'beamwidth_deg': 360,
            'size_cm': 15,
            'cost_usd': 10,
            'portability': 'excellent'
        },
        'yagi_uda': {
            'gain_dbi': 10,
            'beamwidth_deg': 45,
            'size_cm': 50,
            'cost_usd': 50,
            'portability': 'good'
        },
        'patch_array': {
            'gain_dbi': 15,
            'beamwidth_deg': 30,
            'size_cm': 20,
            'cost_usd': 100,
            'portability': 'good'
        },
        'parabolic': {
            'gain_dbi': 25,
            'beamwidth_deg': 10,
            'size_cm': 60,
            'cost_usd': 200,
            'portability': 'fair'
        },
        'helical': {
            'gain_dbi': 12,
            'beamwidth_deg': 60,
            'size_cm': 30,
            'cost_usd': 80,
            'portability': 'good'
        },
        'horn': {
            'gain_dbi': 20,
            'beamwidth_deg': 20,
            'size_cm': 40,
            'cost_usd': 250,
            'portability': 'fair'
        }
    }
    
    @classmethod
    def calculate_range_with_antenna(cls, base_range_m: float, 
                                      antenna_gain_dbi: float,
                                      cable_loss_db: float = 2.0) -> float:
        """
        Calculate increased range with antenna
        Range increases by factor of 2^(gain/10) / 2^(loss/10)
        """
        gain_factor = 10 ** (antenna_gain_dbi / 10)
        loss_factor = 10 ** (cable_loss_db / 10)
        
        new_range = base_range_m * (gain_factor / loss_factor) ** 0.5
        
        return new_range
    
    @classmethod
    def best_antenna_for_range(cls, desired_range_km: float, 
                               base_power_w: float) -> Dict:
        """
        Recommend best antenna for desired range
        """
        recommendations = []
        
        for name, specs in cls.ANTENNA_TYPES.items():
            # Estimate range with this antenna
            estimated_m = 100 * (10 ** (specs['gain_dbi'] / 10)) ** 0.5
            estimated_km = estimated_m / 1000
            
            recommendations.append({
                'antenna': name,
                'gain_dbi': specs['gain_dbi'],
                'estimated_range_km': round(estimated_km, 2),
                'meets_requirement': estimated_km >= desired_range_km,
                'cost_usd': specs['cost_usd'],
                'portability': specs['portability']
            })
        
        # Sort by range
        recommendations.sort(key=lambda x: x['estimated_range_km'], reverse=True)
        
        return {
            'desired_km': desired_range_km,
            'base_power_w': base_power_w,
            'recommendations': recommendations[:5],
            'best_long_range': recommendations[0] if recommendations else None,
            'best_portable': min([r for r in recommendations if r['portability'] in ['excellent', 'good']], 
                                 key=lambda x: -x['estimated_range_km']) if recommendations else None
        }


