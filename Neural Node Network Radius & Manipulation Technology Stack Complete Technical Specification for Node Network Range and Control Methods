                if tool.power_range_w[0] <= power_w <= tool.power_range_w[1]:
                    suitable.append({
                        'name': tool.name,
                        'category': category,
                        'power_w': f"{tool.power_range_w[0]} - {tool.power_range_w[1]}",
                        'precision_mm': tool.precision_mm,
                        'cost_usd': tool.cost_usd,
                        'portability': tool.portability
                    })
        return suitable
    
    @classmethod
    def get_best_method_for_depth(cls, depth_cm: float) -> Dict:
        """Determine best manipulation method for target depth"""
        methods = {
            'rf_stimulation': {'max_depth': 8, 'min_depth': 0, 'precision': 20},
            'magnetic_field': {'max_depth': 7, 'min_depth': 1, 'precision': 5},
            'ultrasound': {'max_depth': 12, 'min_depth': 0, 'precision': 1},
            'electrical': {'max_depth': 3, 'min_depth': 0, 'precision': 2},
            'optical': {'max_depth': 2, 'min_depth': 0, 'precision': 0.1},
        }
        
        best_method = None
        best_score = -1
        
        for method, specs in methods.items():
            if depth_cm <= specs['max_depth']:
                # Score based on precision and depth
                score = (1 / (specs['precision'] + 1)) * (specs['max_depth'] - depth_cm + 1)
                if score > best_score:
                    best_score = score
                    best_method = method
        
        return {
            'recommended_method': best_method,
            'depth_cm': depth_cm,
            'available_methods': methods,
            'precision_mm': methods.get(best_method, {}).get('precision', 0)
        }


