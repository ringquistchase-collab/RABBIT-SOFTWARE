class NetworkRadiusCalculator:
    """
    Calculates maximum range for RF node communication
    Based on frequency, power, antenna gain, and environment
    """
    
    # Frequency bands for neural node communication (GHz)
    FREQUENCY_BANDS = {
        '10ghz': 10.23e9,      # Primary neural band
        '2.4ghz': 2.4e9,       # WiFi backup band
        '5.8ghz': 5.8e9,       # High-speed band
        '868mhz': 868e6,       # Long-range band
        '433mhz': 433e6,       # Extended range band
        '27mhz': 27e6,         # Maximum penetration band
    }
    
    # Environment types and their attenuation factors
    ENVIRONMENTS = {
        'open_air': {'factor': 1.0, 'description': 'Line of sight, no obstacles'},
        'indoor_walls': {'factor': 0.3, 'description': 'Standard walls, furniture'},
        'urban_outdoor': {'factor': 0.5, 'description': 'Buildings, trees, vehicles'},
        'suburban': {'factor': 0.7, 'description': 'Houses, light vegetation'},
        'dense_urban': {'factor': 0.2, 'description': 'Skyscrapers, dense structures'},
        'underground': {'factor': 0.05, 'description': 'Basements, tunnels'},
        'forest': {'factor': 0.4, 'description': 'Trees, vegetation'},
        'hospital': {'factor': 0.25, 'description': 'Medical equipment, shielding'},
    }
    
    # Standard power levels (dBm and Watts)
    POWER_LEVELS = {
        'ultra_low': (-30, 0.000001),   # 1 μW
        'very_low': (-20, 0.00001),     # 10 μW
        'low': (-10, 0.0001),           # 100 μW
        'medium': (0, 0.001),           # 1 mW
        'high': (10, 0.01),             # 10 mW
        'very_high': (20, 0.1),         # 100 mW
        'maximum_safe': (30, 1.0),      # 1 W (FCC limit for ISM bands)
        'experimental': (40, 10.0),     # 10 W (license required)
    }
    
    @classmethod
    def calculate_freespace_range(cls, frequency_hz: float, 
                                   power_dbm: float,
                                   tx_gain_dbi: float,
                                   rx_gain_dbi: float,
                                   sensitivity_dbm: float = -100) -> float:
        """
        Calculate maximum range in free space (ideal conditions)
        Using Friis transmission equation
        """
        # Convert dBm to linear power
        power_w = 10 ** ((power_dbm - 30) / 10)
        
        # Wavelength (meters)
        wavelength = 299792458 / frequency_hz
        
        # Total gain
        total_gain_linear = 10 ** ((tx_gain_dbi + rx_gain_dbi) / 10)
        
        # Receiver sensitivity in linear
        sensitivity_w = 10 ** ((sensitivity_dbm - 30) / 10)
        
        # Calculate free space range (meters)
        range_m = wavelength * math.sqrt((power_w * total_gain_linear) / 
                                          (sensitivity_w * (4 * math.pi) ** 2))
        
        return range_m
    
    @classmethod
    def calculate_real_range(cls, frequency_hz: float,
                              power_dbm: float,
                              environment: str,
                              obstacle_factor: float = 0.5) -> Dict:
        """
        Calculate realistic range considering environment
        """
        # Get environment attenuation
        env = cls.ENVIRONMENTS.get(environment, cls.ENVIRONMENTS['open_air'])
        
        # Calculate ideal range
        ideal_range = cls.calculate_freespace_range(
            frequency_hz, power_dbm, 2.0, 2.0, -95
        )
        
        # Apply environment factor
        real_range = ideal_range * env['factor']
        
        # Apply obstacle factor (additional attenuation)
        real_range = real_range * obstacle_factor
        
        return {
            'ideal_range_meters': round(ideal_range, 2),
            'realistic_range_meters': round(real_range, 2),
            'environment': environment,
            'environment_factor': env['factor'],
            'obstacle_factor': obstacle_factor,
            'usable_range_km': round(real_range / 1000, 3)
        }
    
    @classmethod
    def all_configurations(cls) -> Dict:
        """Calculate ranges for all common configurations"""
        results = {}
        
        configurations = [
            # (name, frequency, power_dbm, environment)
            ('Body Area Network', cls.FREQUENCY_BANDS['10ghz'], -10, 'indoor_walls'),
            ('Room Scale', cls.FREQUENCY_BANDS['2.4ghz'], 0, 'indoor_walls'),
            ('Building Scale', cls.FREQUENCY_BANDS['868mhz'], 10, 'indoor_walls'),
            ('Campus Scale', cls.FREQUENCY_BANDS['433mhz'], 20, 'suburban'),
            ('City Block', cls.FREQUENCY_BANDS['27mhz'], 30, 'urban_outdoor'),
            ('Long Range', cls.FREQUENCY_BANDS['433mhz'], 30, 'open_air'),
        ]
        
        for name, freq, power, env in configurations:
            results[name] = cls.calculate_real_range(freq, power, env, 0.5)
        
        return results


