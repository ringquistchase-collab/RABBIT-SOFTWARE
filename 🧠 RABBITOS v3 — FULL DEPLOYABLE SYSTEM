🧾 7. POSTGRES AUDIT LOGGING

import psycopg2
import json

conn = psycopg2.connect(
    dbname="rabbitos",
    user="rabbit",
    password="rabbit",
    host="postgres"
)

def log_event(event):
    cur = conn.cursor()
    cur.execute(
        "INSERT INTO logs (data) VALUES (%s)",
        (json.dumps(event),)
    )
    conn.commit()


