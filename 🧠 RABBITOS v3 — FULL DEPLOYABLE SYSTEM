🧬 6. VECTOR MEMORY (QDRANT)

from qdrant_client import QdrantClient

client = QdrantClient(url="http://qdrant:6333")

def store_memory(id, vector, payload):
    client.upsert(
        collection_name="rabbit_memory",
        points=[{
            "id": id,
            "vector": vector,
            "payload": payload
        }]
    )


