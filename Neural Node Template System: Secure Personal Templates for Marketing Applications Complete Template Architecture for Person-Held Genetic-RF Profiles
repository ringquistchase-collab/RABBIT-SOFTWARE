class TemplateFeature(Enum):
    """Types of features that can be extracted from node templates"""
    # Demographic (anonymized)
    AGE_GROUP = "age_group"
    GENDER_GROUP = "gender_group"
    REGION = "region"
    
    # Behavioral
    ATTENTION_SCORE = "attention_score"
    ENGAGEMENT_LEVEL = "engagement_level"
    EMOTIONAL_VALENCE = "emotional_valence"
    COGNITIVE_LOAD = "cognitive_load"
    
    # Preferences (inferred, not stored)
    PRODUCT_INTEREST = "product_interest"
    CONTENT_PREFERENCE = "content_preference"
    SHOPPING_INTENT = "shopping_intent"
    
    # Temporal
    TIME_OF_DAY = "time_of_day"
    DAY_OF_WEEK = "day_of_week"
    SESSION_DURATION = "session_duration"


class TemplatePermission(Enum):
    """Permission levels for template access"""
    NONE = 0
    BASIC_DEMOGRAPHIC = 1
    BEHAVIORAL = 2
    PREFERENCE_INFERRED = 3
    FULL_ANONYMIZED = 4


@dataclass
class NeuralNodeTemplate:
    """
    A template derived from a person's neural node network
    Contains ONLY derived features - cannot reverse to original data
    Each template is unique to the person but standardized for models
    """
    
    # Template identification
    template_id: str
    person_hash: str  # One-way hash of person's DNA/node ID
    created_at: float
    version: str
    
    # Core template data (derived features, not raw)
    feature_vector: np.ndarray  # Normalized 0-1 features
    feature_names: List[str]
    feature_hashes: List[str]   # Hash of each feature for verification
    
    # Permission layers
    available_permissions: List[TemplatePermission]
    
    # Template signature (prevents tampering)
    signature: str
    issuer: str  # Who created the template (person's device)
    
    # Usage tracking (local only)
    usage_count: int = 0
    last_used: float = 0
    used_by_models: List[str] = field(default_factory=list)


class NeuralNodeTemplateEngine:
    """
    Engine that creates and manages templates from neural nodes
    Templates are generated ON the person's device - never leave
    Models receive SANITIZED templates that cannot reveal identity
    """
    
    # Template version
    TEMPLATE_VERSION = "2.0"
    
    # Feature extraction methods
    FEATURE_EXTRACTORS = {
        TemplateFeature.AGE_GROUP: lambda x: x.get('age', 30) // 10,
        TemplateFeature.ATTENTION_SCORE: lambda x: x.get('attention', 0.5),
        TemplateFeature.ENGAGEMENT_LEVEL: lambda x: x.get('engagement', 0.5),
        TemplateFeature.EMOTIONAL_VALENCE: lambda x: x.get('valence', 0.5),
        TemplateFeature.COGNITIVE_LOAD: lambda x: x.get('cognitive_load', 0.3),
        TemplateFeature.TIME_OF_DAY: lambda x: time.localtime().tm_hour // 4,
    }
    
    def __init__(self, person_device_id: str):
        """
        Initialize template engine on person's device
        All templates stay LOCAL
        """
        self.person_device_id = person_device_id
        self.device_key = hashlib.sha3_256(person_device_id.encode()).digest()
        
        # Local template storage (never leaves device)
        self.templates: Dict[str, NeuralNodeTemplate] = {}
        self.active_template = None
        
        # Node state (simulated from neural nodes)
        self.node_state = self._get_current_node_state()
        
        print(f"\n{'='*60}")
        print(f"🔐 NEURAL NODE TEMPLATE ENGINE")
        print(f"   Device: {person_device_id}")
        print(f"   Templates stored: LOCAL ONLY")
        print(f"   Templates never leave person's control")
        print(f"{'='*60}")
    
    def _get_current_node_state(self) -> Dict:
        """
        Get current state from neural nodes (simulated)
        In production: reads from actual SDR/EEG nodes
        """
        return {
            'attention': np.random.uniform(0.3, 0.9),
            'engagement': np.random.uniform(0.4, 0.8),
            'valence': np.random.uniform(0.2, 0.8),
            'cognitive_load': np.random.uniform(0.1, 0.6),
            'age': np.random.randint(18, 65),
            'gender': np.random.choice(['M', 'F', 'X']),
            'region': np.random.choice(['NA', 'EU', 'APAC', 'LATAM']),
            'interests': ['tech', 'fashion', 'sports', 'music']
        }
    
    def create_person_template(self, 
                               template_name: str,
                               permission_level: TemplatePermission,
                               features_to_include: List[TemplateFeature]) -> NeuralNodeTemplate:
        """
        Create a new template from current node state
        Template contains ONLY derived features - not raw data
        Person chooses what to include
        """
        # Generate template ID
        template_id = hashlib.sha3_256(
            f"{self.person_device_id}_{template_name}_{time.time()}".encode()
        ).hexdigest()[:16]
        
        # Person hash (one-way, cannot reverse)
        person_hash = hashlib.sha3_256(self.person_device_id.encode()).hexdigest()[:32]
        
        # Extract features based on current node state
        feature_vector = []
        feature_names = []
        feature_hashes = []
        
        for feature in features_to_include:
            if feature in self.FEATURE_EXTRACTORS:
                value = self.FEATURE_EXTRACTORS[feature](self.node_state)
                
                # Normalize to 0-1 range
                if isinstance(value, (int, float)):
                    norm_value = min(1.0, max(0.0, value / 10 if value > 1 else value))
                else:
                    norm_value = hash(str(value)) % 100 / 100.0
                
                feature_vector.append(norm_value)
                feature_names.append(feature.value)
                
                # Feature hash for verification
                feature_hashes.append(
                    hashlib.sha3_256(f"{feature.value}:{norm_value}:{self.device_key[:8]}".encode()).hexdigest()[:16]
                )
        
        # Convert to numpy array
        feature_array = np.array(feature_vector)
        
        # Create template signature
        signature_material = f"{template_id}{person_hash}{feature_array.tobytes()}{self.device_key.hex()}"
        signature = hashlib.sha3_256(signature_material.encode()).hexdigest()[:32]
        
        template = NeuralNodeTemplate(
            template_id=template_id,
            person_hash=person_hash,
            created_at=time.time(),
            version=self.TEMPLATE_VERSION,
            feature_vector=feature_array,
            feature_names=feature_names,
            feature_hashes=feature_hashes,
            available_permissions=[permission_level],
            signature=signature,
            issuer=self.person_device_id
        )
        
        # Store locally
        self.templates[template_id] = template
        self.active_template = template
        
        print(f"\n📋 TEMPLATE CREATED: {template_name}")
        print(f"   ID: {template_id}")
        print(f"   Features: {len(feature_names)}")
        print(f"   Permission Level: {permission_level.name}")
        print(f"   Template stored: LOCAL ONLY")
        
        return template
    
    def generate_sharable_template(self, 
                                   template_id: str,
                                   requesting_model: str,
                                   permission_level: TemplatePermission) -> Dict:
        """
        Generate a SHARABLE version of the template
        Contains ONLY authorized features - identity protected
        This is what gets sent to marketing models
        """
        if template_id not in self.templates:
            return {'error': 'Template not found'}
        
        template = self.templates[template_id]
        
        # Check permission level
        if permission_level not in template.available_permissions:
            return {'error': f'Permission {permission_level.name} not granted'}
        
        # Create sanitized template (no identifying info)
        sharable = {
            'template_id': template.template_id,
            'version': template.version,
            'created_at': template.created_at,
            
            # Anonymized person identifier (not reversible)
            'person_anonymized': hashlib.blake2b(
                template.person_hash.encode(), 
                digest_size=16
            ).hexdigest(),
            
            # Feature vector (derived, not raw)
            'features': {
                name: float(value) 
                for name, value in zip(template.feature_names, template.feature_vector)
            },
            
            # Feature hashes for verification
            'feature_hashes': template.feature_hashes,
            
            # Permission level granted
            'permission_level': permission_level.name,
            
            # Template signature (verify authenticity)
            'signature': template.signature,
            
            # Usage metadata
            'valid_until': time.time() + (30 * 24 * 3600),  # 30 days
            'model_id': requesting_model
        }
        
        # Add a one-time use token for this model
        sharable['access_token'] = hmac.new(
            self.device_key,
            f"{template_id}{requesting_model}{time.time()}".encode(),
            hashlib.sha3_256
        ).hexdigest()[:32]
        
        # Update usage tracking
        template.usage_count += 1
        template.last_used = time.time()
        template.used_by_models.append(requesting_model)
        
        print(f"\n📤 SHARABLE TEMPLATE GENERATED")
        print(f"   Model: {requesting_model}")
        print(f"   Permission: {permission_level.name}")
        print(f"   Features: {len(sharable['features'])}")
        print(f"   Valid Until: {sharable['valid_until']}")
        
        return sharable
    
    def verify_template(self, sharable_template: Dict, model_id: str) -> bool:
        """
        Verify that a template is authentic and not tampered
        Called by marketing model BEFORE using template
        """
        # Verify signature
        expected_sig = hashlib.sha3_256(
            f"{sharable_template['template_id']}"
            f"{sharable_template['person_anonymized']}"
            f"{json.dumps(sharable_template['features'], sort_keys=True)}"
        .encode()).hexdigest()[:32]
        
        if expected_sig != sharable_template.get('signature', ''):
            print(f"❌ Template signature invalid")
            return False
        
        # Verify access token
        # In production: check with person's device
        print(f"✅ Template verified for {model_id}")
        return True
    
    def revoke_template_access(self, template_id: str, model_id: str) -> Dict:
        """Revoke a model's access to a template"""
        if template_id not in self.templates:
            return {'error': 'Template not found'}
        
        template = self.templates[template_id]
        
        if model_id in template.used_by_models:
            template.used_by_models.remove(model_id)
            print(f"\n🔒 Revoked access for {model_id}")
            return {'revoked': True, 'model': model_id}
        
        return {'revoked': False, 'reason': 'Model not in access list'}


