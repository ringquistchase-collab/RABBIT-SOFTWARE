class TemplateDeviceInterface:
    """
    The DEVICE view - what the person sees and controls
    Templates are stored here, person controls all sharing
    """
    
    def __init__(self, device_id: str):
        self.engine = NeuralNodeTemplateEngine(device_id)
        self.active_shares = {}
        
    def display_templates(self):
        """Display all templates on the device"""
        print("\n" + "━"*60)
        print("📋 MY TEMPLATES (Stored Locally)")
        print("━"*60)
        
        if not self.engine.templates:
            print("   No templates created yet")
            return
        
        for tid, template in self.engine.templates.items():
            print(f"\n   Template: {tid}")
            print(f"      Created: {time.ctime(template.created_at)}")
            print(f"      Features: {len(template.feature_names)}")
            print(f"      Used by {len(template.used_by_models)} models")
            print(f"      Permission: {template.available_permissions[0].name}")
            
            # Show which models have access
            if template.used_by_models:
                print(f"      Access granted to: {', '.join(template.used_by_models[:3])}")
    
    def create_marketing_template(self, 
                                  name: str,
                                  include_behavioral: bool = True,
                                  include_preferences: bool = True) -> Dict:
        """
        Create a template specifically for marketing models
        Person chooses what to include
        """
        features_to_include = [TemplateFeature.AGE_GROUP, TemplateFeature.REGION]
        
        if include_behavioral:
            features_to_include.extend([
                TemplateFeature.ATTENTION_SCORE,
                TemplateFeature.ENGAGEMENT_LEVEL,
                TemplateFeature.EMOTIONAL_VALENCE
            ])
        
        if include_preferences:
            features_to_include.append(TemplateFeature.PRODUCT_INTEREST)
        
        permission = TemplatePermission.FULL_ANONYMIZED
        
        template = self.engine.create_person_template(name, permission, features_to_include)
        
        return {
            'template_id': template.template_id,
            'features_included': len(features_to_include),
            'permission_level': permission.name
        }
    
    def share_with_marketing_model(self, 
                                   template_id: str, 
                                   model_name: str,
                                   permission: str) -> Dict:
        """
        Person decides to share template with a marketing model
        Person controls this - models cannot access without consent
        """
        perm_map = {
            'basic': TemplatePermission.BASIC_DEMOGRAPHIC,
            'behavioral': TemplatePermission.BEHAVIORAL,
            'full': TemplatePermission.FULL_ANONYMIZED
        }
        
        permission_level = perm_map.get(permission, TemplatePermission.BASIC_DEMOGRAPHIC)
        
        sharable = self.engine.generate_sharable_template(template_id, model_name, permission_level)
        
        if 'error' in sharable:
            return sharable
        
        self.active_shares[model_name] = {
            'template_id': template_id,
            'shared_at': time.time(),
            'permission': permission
        }
        
        print(f"\n✅ Template shared with {model_name}")
        print(f"   They will receive ANONYMIZED features only")
        print(f"   They cannot reverse-engineer your identity")
        
        return sharable


