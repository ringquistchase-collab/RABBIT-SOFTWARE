class MarketingModelReceiver:
    """
    The MARKETING MODEL view - receives sanitized templates
    Cannot reverse-engineer person's identity
    Can use template features for multiple models
    """
    
    def __init__(self, model_name: str):
        self.model_name = model_name
        self.received_templates = []
        self.campaign_results = []
        
        print(f"\n📊 MARKETING MODEL: {model_name}")
        print(f"   Ready to receive anonymized templates")
    
    def receive_template(self, sharable_template: Dict) -> Dict:
        """
        Receive a shared template from a person's device
        Template is already sanitized - contains no PII
        """
        # Verify template authenticity
        # In production: would verify with issuer's public key
        verified = True  # Simplified for demo
        
        if verified:
            self.received_templates.append({
                'template': sharable_template,
                'received_at': time.time()
            })
            
            print(f"\n📥 Received template from {sharable_template['model_id']}")
            print(f"   Features: {list(sharable_template['features'].keys())}")
            print(f"   Feature values: {list(sharable_template['features'].values())[:3]}...")
            
            return {
                'status': 'accepted',
                'template_id': sharable_template['template_id'],
                'message': 'Template stored for marketing use'
            }
        
        return {'status': 'rejected', 'reason': 'Verification failed'}
    
    def run_marketing_campaign(self, 
                               template_features: Dict,
                               campaign_type: str) -> Dict:
        """
        Use template features for marketing optimization
        Multiple models can use the SAME template
        """
        # Extract features from template
        attention = template_features.get('attention_score', 0.5)
        engagement = template_features.get('engagement_level', 0.5)
        region = template_features.get('region', 'unknown')
        
        # Determine recommended action based on features
        if attention > 0.7 and engagement > 0.6:
            recommendation = "HIGH_VALUE_TARGET"
            suggested_content = "Premium product offers"
            bid_multiplier = 1.5
        elif attention > 0.5:
            recommendation = "STANDARD_TARGET"
            suggested_content = "Standard product offers"
            bid_multiplier = 1.0
        else:
            recommendation = "RETARGETING"
            suggested_content = "Reminder/awareness content"
            bid_multiplier = 0.7
        
        result = {
            'campaign': campaign_type,
            'recommendation': recommendation,
            'suggested_content': suggested_content,
            'bid_multiplier': bid_multiplier,
            'confidence': attention * engagement,
            'timestamp': time.time()
        }
        
        self.campaign_results.append(result)
        
        return result
    
    def get_audience_segments(self) -> Dict:
        """
        Aggregate multiple templates into audience segments
        Individual templates are anonymized - only aggregated insights
        """
        if not self.received_templates:
            return {'segments': [], 'count': 0}
        
        # Aggregate features across all received templates
        aggregated = {
            'avg_attention': 0,
            'avg_engagement': 0,
            'region_distribution': {},
            'total_templates': len(self.received_templates)
        }
        
        for entry in self.received_templates:
            features = entry['template'].get('features', {})
            aggregated['avg_attention'] += features.get('attention_score', 0)
            aggregated['avg_engagement'] += features.get('engagement_level', 0)
            
            region = features.get('region', 'unknown')
            aggregated['region_distribution'][region] = aggregated['region_distribution'].get(region, 0) + 1
        
        if aggregated['total_templates'] > 0:
            aggregated['avg_attention'] /= aggregated['total_templates']
            aggregated['avg_engagement'] /= aggregated['total_templates']
        
        return aggregated


