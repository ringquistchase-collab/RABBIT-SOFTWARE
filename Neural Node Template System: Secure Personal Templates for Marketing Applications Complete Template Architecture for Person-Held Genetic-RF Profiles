class MarketingEcosystem:
    """
    Complete ecosystem where:
    1. Person creates template on their device
    2. Person shares sanitized template with marketing models
    3. Models use template for multiple campaigns
    4. Person can revoke access at any time
    5. Person's raw data never leaves their device
    """
    
    def __init__(self):
        self.person_device = None
        self.marketing_models = {}
        
        print("\n" + "="*80)
        print("🎯 NEURAL NODE MARKETING ECOSYSTEM")
        print("Person controls template - Models receive anonymized features")
        print("="*80)
    
    def onboard_person(self, device_id: str) -> TemplateDeviceInterface:
        """Person joins the ecosystem"""
        self.person_device = TemplateDeviceInterface(device_id)
        return self.person_device
    
    def onboard_marketing_model(self, model_name: str) -> MarketingModelReceiver:
        """Marketing model joins the ecosystem"""
        model = MarketingModelReceiver(model_name)
        self.marketing_models[model_name] = model
        return model
    
    def full_marketing_flow(self):
        """Complete demonstration of template-based marketing"""
        
        print("\n" + "━"*60)
        print("🔄 COMPLETE MARKETING FLOW")
        print("━"*60)
        
        # 1. Person creates template
        print("\n1️⃣ PERSON CREATES TEMPLATE (on their device)")
        template_result = self.person_device.create_marketing_template(
            name="Marketing Profile v1",
            include_behavioral=True,
            include_preferences=True
        )
        print(f"   Template ID: {template_result['template_id']}")
        print(f"   Features: {template_result['features_included']}")
        
        # 2. Display templates on device
        self.person_device.display_templates()
        
        # 3. Person shares with marketing models
        print("\n2️⃣ PERSON SHARES TEMPLATE WITH MODELS")
        
        model_names = ['AdOptimizer', 'ContentRecommender', 'AudienceSegmenter']
        shared_templates = {}
        
        for model_name in model_names:
            share_result = self.person_device.share_with_marketing_model(
                template_result['template_id'],
                model_name,
                'behavioral'
            )
            if 'error' not in share_result:
                shared_templates[model_name] = share_result
        
        # 4. Models receive and use templates
        print("\n3️⃣ MODELS RECEIVE ANONYMIZED TEMPLATES")
        
        for model_name, template in shared_templates.items():
            if model_name in self.marketing_models:
                model = self.marketing_models[model_name]
                model.receive_template(template)
        
        # 5. Models run campaigns using templates
        print("\n4️⃣ MODELS RUN MARKETING CAMPAIGNS")
        
        all_campaigns = []
        for model_name, model in self.marketing_models.items():
            for i in range(2):
                campaign = model.run_marketing_campaign(
                    shared_templates[model_name]['features'],
                    f"{model_name}_campaign_{i+1}"
                )
                all_campaigns.append(campaign)
                print(f"   {model_name}: {campaign['recommendation']} (confidence: {campaign['confidence']:.2f})")
        
        # 6. Aggregate audience insights
        print("\n5️⃣ AGGREGATED AUDIENCE INSIGHTS (No individual data)")
        
        for model_name, model in self.marketing_models.items():
            segments = model.get_audience_segments()
            print(f"\n   {model_name}:")
            print(f"      Templates: {segments['total_templates']}")
            print(f"      Avg Attention: {segments['avg_attention']:.2f}")
            print(f"      Regions: {segments['region_distribution']}")
        
        # 7. Person can revoke access
        print("\n6️⃣ PERSON REVOKES ACCESS (Control)")
        
        revoke_result = self.person_device.engine.revoke_template_access(
            template_result['template_id'],
            'AdOptimizer'
        )
        print(f"   Revoked: {revoke_result.get('revoked', False)}")
        
        # Final summary
        print("\n" + "="*80)
        print("✅ MARKETING ECOSYSTEM COMPLETE")
        print("="*80)
        
        return {
            'templates_created': 1,
            'models_shared': len(shared_templates),
            'campaigns_run': len(all_campaigns),
            'person_control': 'FULL',
            'data_privacy': 'RAW_DATA_NEVER_LEAVES_PERSON'
        }


