🧠 1. SYSTEM STATE MODEL (GLOBAL MEMORY)

# system_state_model.py

class SystemState:
    def __init__(self):
        self.services = {}
        self.nodes = {}
        self.health_score = 1.0
        self.incidents = []

    def update_service(self, name, status):
        self.services[name] = status

    def register_incident(self, incident):
        self.incidents.append(incident)
        self.health_score -= 0.05


