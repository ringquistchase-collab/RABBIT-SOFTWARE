🧠 4. ROOT CAUSE AI ENGINE

# root_cause_ai.py

class RootCauseAI:
    def analyze(self, anomalies):
        if "HIGH_CPU" in anomalies:
            return "OVERLOAD"
        if "HIGH_LATENCY" in anomalies:
            return "NETWORK_BOTTLENECK"
        if "HIGH_ERROR_RATE" in anomalies:
            return "FAILED_DEPLOYMENT"
        return "UNKNOWN"


