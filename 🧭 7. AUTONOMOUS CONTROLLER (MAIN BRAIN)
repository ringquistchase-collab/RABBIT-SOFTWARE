🚨 3. ANOMALY DETECTOR (STAT + AI HYBRID)

# anomaly_detector.py

def detect(metrics):
    anomalies = []

    if metrics["cpu"] > 85:
        anomalies.append("HIGH_CPU")

    if metrics["latency_ms"] > 200:
        anomalies.append("HIGH_LATENCY")

    if metrics["error_rate"] > 0.1:
        anomalies.append("HIGH_ERROR_RATE")

    return anomalies


