📡 2. METRICS COLLECTOR (REAL-TIME TELEMETRY)

# metrics_collector.py

import time
import random

def collect_metrics():
    return {
        "cpu": random.uniform(10, 95),
        "latency_ms": random.uniform(1, 300),
        "error_rate": random.uniform(0, 0.2),
        "memory": random.uniform(30, 90)
    }

def stream():
    while True:
        yield collect_metrics()
        time.sleep(1)


