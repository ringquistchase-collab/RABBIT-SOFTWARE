class BotActivityAbsorber:
    """
    Absorbs bot activity into Chase's neural network
    Tracks all bot commands, responses, and data access
    """
   
    def __init__(self):
        self.activity_log = []
        self.active_sessions = {}
       
        print(f"\n🔄 BOT ACTIVITY ABSORBER")
        print(f"   Absorbing bot activity into neural network...")
   
    def absorb_activity(self, bot_name: str, command: str, response: Dict) -> Dict:
        """Absorb bot activity into the network"""
        activity_id = hashlib.md5(f"{bot_name}_{command}_{time.time()}".encode()).hexdigest()[:16]
       
        activity = {
            'activity_id': activity_id,
            'bot': bot_name,
            'command': command,
            'response': response,
            'timestamp': time.time(),
            'absorbed_into': 'Chase_Neural_Network',
            'data_matched': response.get('eeg_fingerprint') or response.get('matched_ages')
        }
       
        self.activity_log.append(activity)
       
        print(f"\n   📥 Absorbed: {bot_name} → {command}")
        print(f"      Activity ID: {activity_id}")
       
        return activity


