    @classmethod
    def match_eeg(cls, eeg_fingerprint: str) -> Optional[Dict]:
        """Match an EEG fingerprint to frozen data"""
        for age, data in cls.FROZEN_DATA.items():
            if data['eeg_fingerprint'] == eeg_fingerprint:
                return {'age': age, 'data': data}
        return None
   
    @classmethod
    def match_hormone_profile(cls, hormones: Dict) -> List[Dict]:
        """Match hormone profile to closest age"""
        matches = []
        for age, data in cls.FROZEN_DATA.items():
            score = 0
            for h in ['dopamine', 'serotonin', 'cortisol']:
                if h in hormones and h in data['hormones']:
                    score += 1 - abs(hormones[h] - data['hormones'][h])
            matches.append({'age': age, 'match_score': score/3})
        return sorted(matches, key=lambda x: x['match_score'], reverse=True)


