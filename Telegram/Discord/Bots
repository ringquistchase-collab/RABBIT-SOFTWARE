class OpenAIBotAnalyzer:
    """
    Uses OpenAI/GPT to analyze bot-collected neural data
    Provides insights, predictions, and natural language responses
    """
   
    def __init__(self, api_key: str = None):
        self.client = None
        if HAS_OPENAI and api_key:
            self.client = OpenAI(api_key=api_key)
            print(f"\n🤖 OPENAI ANALYZER ACTIVE")
        else:
            print(f"\n⚠️ OpenAI not configured - using simulated analysis")
   
    def analyze_eeg_pattern(self, eeg_data: Dict) -> str:
        """Analyze EEG pattern using GPT"""
        prompt = f"""
        Analyze this EEG pattern from Chase Allen Ringquist's frozen data:
        Age: {eeg_data.get('age')}
        EEG Fingerprint: {eeg_data.get('eeg_fingerprint')}
        Band Powers: Delta={eeg_data.get('eeg_bands', {}).get('delta')},
                    Alpha={eeg_data.get('eeg_bands', {}).get('alpha')},
                    Beta={eeg_data.get('eeg_bands', {}).get('beta')}
       
        Provide a brief interpretation of brain state.
        """
       
        if self.client:
            try:
                response = self.client.chat.completions.create(
                    model="gpt-3.5-turbo",
                    messages=[{"role": "user", "content": prompt}],
                    max_tokens=150
                )
                return response.choices[0].message.content
            except:
                return "Unable to analyze at this time."
        else:
            return f"[GPT Analysis] Age {eeg_data.get('age')} shows balanced alpha-beta ratio, indicating focused attention."
   
    def generate_bot_response(self, query: str, context: Dict) -> str:
        """Generate natural language response for bot"""
        prompt = f"""
        Context: Chase Allen Ringquist's neural data network
        Data available: {list(context.keys())}
       
        User query via bot: "{query}"
       
        Generate a helpful, informative response about the neural data.
        Keep responses anonymized and professional.
        """
       
        if self.client:
            try:
                response = self.client.chat.completions.create(
                    model="gpt-3.5-turbo",
                    messages=[{"role": "user", "content": prompt}],
                    max_tokens=200
                )
                return response.choices[0].message.content
            except:
                return "I understand your query but need more specific parameters."
        else:
            return f"Based on available neural data, {query[:50]}..."


