Nodes 17-26: Extremities (Motor/Reflex - Latency Monitoring)
2. The Simulation Engine (Python)

import numpy as np
import hashlib
import json
import time

class RabbitCorpusBuilder:
    def __init__(self):
        self.nodes = [f"NODE_{i:02d}" for i in range(1, 27)]
        self.carrier_hz = 10.245e9
        self.resolution_ms = 1.2
        
    def generate_tfm_token(self, signal_value, intensity):
        """Mimics the TFM-EEG tokenization logic from the repo."""
        raw_string = f"{signal_value:.4f}-{intensity}"
        return hashlib.sha256(raw_string.encode()).hexdigest()[:8].upper()

    def simulate_continuum(self, seconds=60):
        corpus = []
        print(f"Generating Corpus: 26 Nodes | {seconds}s | 1.2ms Frames")

        for sec in range(seconds):
            # Calculate Intensity (0.0 = Low/Zen, 1.0 = High/Stress)
            # This creates the 'In-Between' data by shifting intensity over time
            intensity = sec / seconds 
            
            frame = {
                "timestamp": sec,
                "intensity_level": round(intensity * 10, 2),
                "state": "TRANSITION",
                "nodes": {}
            }
            
            if intensity < 0.3: frame["state"] = "LOW_STRESS_ZEN"
            elif intensity > 0.7: frame["state"] = "HIGH_STRESS_SHOCK"

            for node in self.nodes:
                # Physics-based signal generation
                if "01" <= node[-2:] <= "08": # Brain Nodes
                    freq = np.interp(intensity, [0, 1], [8, 40]) # Alpha to Gamma shift
                    val = np.sin(2 * np.pi * freq * (sec/60))
                else: # Body Nodes
                    freq = np.interp(intensity, [0, 1], [1, 5]) # GSR Activity
                    val = np.cos(2 * np.pi * freq * (sec/60)) * intensity

                frame["nodes"][node] = {
                    "token": self.generate_tfm_token(val, intensity),
                    "phase_shift": round(val * intensity, 4),
                    "latency_ms": round(1.2 + (intensity * 0.5), 4) # Stress increases jitter
                }
            
            corpus.append(frame)
        return corpus

# Initialize the Build
builder = RabbitCorpusBuilder()
synthetic_corpus = builder.simulate_continuum(60)

